<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= t.dir %>" class="scroll-smooth">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title><%= t.brandName %> - <%= t.cartCheckout %></title>
    <link rel="icon" type="image/svg+xml" href="/images/logo/icon.svg" />
    <link rel="apple-touch-icon" href="/images/logo/icon.svg" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&amp;family=Quicksand:wght@400;500;600;700&amp;family=Cairo:wght@400;600;700;750&amp;display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
    <script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            "colors": {
              "primary-container": "#b8583d",
              "on-background": "#1d1c18",
              "surface-container-high": "#ece7e1",
              "on-secondary-fixed": "#291800",
              "surface": "#fef9f2",
              "secondary-fixed-dim": "#fabb57",
              "error-container": "#ffdad6",
              "on-error": "#ffffff",
              "on-surface-variant": "#56423d",
              "secondary-fixed": "#ffddb0",
              "on-secondary-fixed-variant": "#614000",
              "tertiary-fixed-dim": "#b7cda8",
              "on-secondary": "#ffffff",
              "on-secondary-container": "#734d00",
              "surface-variant": "#e6e2db",
              "on-primary-fixed-variant": "#7d2c14",
              "tertiary": "#4e6143",
              "on-tertiary-container": "#f8ffee",
              "inverse-on-surface": "#f5f0e9",
              "secondary-container": "#fdbe5a",
              "on-primary-fixed": "#3b0900",
              "surface-dim": "#ded9d3",
              "surface-container-highest": "#e6e2db",
              "on-primary": "#ffffff",
              "on-tertiary-fixed": "#0f2008",
              "on-surface": "#1d1c18",
              "secondary": "#805600",
              "surface-tint": "#9c4329",
              "error": "#ba1a1a",
              "on-primary-container": "#fffbff",
              "primary": "#994127",
              "tertiary-container": "#667a5a",
              "primary-fixed-dim": "#ffb5a0",
              "outline-variant": "#dcc1ba",
              "primary-fixed": "#ffdbd1",
              "on-tertiary": "#ffffff",
              "on-error-container": "#93000a",
              "background": "#fef9f2",
              "inverse-surface": "#32302c",
              "outline": "#89726c",
              "surface-bright": "#fef9f2",
              "on-tertiary-fixed-variant": "#394c2f",
              "tertiary-fixed": "#d3e9c3",
              "surface-container-lowest": "#ffffff",
              "inverse-primary": "#ffb5a0",
              "surface-container-low": "#f8f3ec",
              "surface-container": "#f2ede6"
            },
            "borderRadius": {
              "DEFAULT": "0.25rem",
              "lg": "0.5rem",
              "xl": "0.75rem",
              "full": "9999px"
            },
            "spacing": {
              "xs": "4px",
              "gutter": "24px",
              "sm": "12px",
              "lg": "48px",
              "md": "24px",
              "base": "8px",
              "container-max": "1200px",
              "xl": "80px"
            },
            "fontFamily": {
              "body-lg": ["<%= lang === 'ar' ? 'Cairo' : 'Quicksand' %>", "sans-serif"],
              "body-md": ["<%= lang === 'ar' ? 'Cairo' : 'Quicksand' %>", "sans-serif"],
              "headline-lg": ["<%= lang === 'ar' ? 'Cairo' : 'Playfair Display' %>", "serif"],
              "headline-md": ["<%= lang === 'ar' ? 'Cairo' : 'Playfair Display' %>", "serif"],
              "headline-lg-mobile": ["<%= lang === 'ar' ? 'Cairo' : 'Playfair Display' %>", "serif"],
              "label-md": ["<%= lang === 'ar' ? 'Cairo' : 'Quicksand' %>", "sans-serif"],
              "label-sm": ["<%= lang === 'ar' ? 'Cairo' : 'Quicksand' %>", "sans-serif"],
              "headline-xl": ["<%= lang === 'ar' ? 'Cairo' : 'Playfair Display' %>", "serif"]
            }
          },
        },
      }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            vertical-align: middle;
        }
        .linen-texture {
            position: fixed;
            inset: 0;
            z-index: -1;
            opacity: 0.04;
            pointer-events: none;
            background-image: url("https://www.transparenttextures.com/patterns/linen.png");
        }
    </style>
    <style>
        body {
            min-height: max(884px, 100dvh);
        }
    </style>
</head>
<body class="bg-background text-on-background font-body-md min-h-screen flex flex-col relative antialiased">
    <div class="linen-texture"></div>

    <!-- TopAppBar -->
    <header class="sticky top-0 w-full z-50 bg-surface/90 backdrop-blur-md shadow-sm">
        <nav class="flex justify-between items-center h-20 px-gutter max-w-container-max mx-auto">
            <div class="flex items-center gap-4">
                <button onclick="toggleMobileDrawer()" class="material-symbols-outlined text-primary text-2xl active:scale-95 duration-200 select-none cursor-pointer bg-transparent border-none p-0 leading-none" style="font-family:'Material Symbols Outlined';user-select:none;-webkit-user-select:none">menu</button>
                <a href="/" class="flex items-center">
                    <img src="/images/logo/lockup.svg" alt="Hayla - Authentic Egyptian Homemade Food" class="h-10 md:h-12 w-auto" />
                </a>
            </div>
            <div class="hidden md:flex gap-8 items-center">
                <a class="font-label-md text-on-surface-variant hover:text-primary transition-colors" href="/"><%= t.navHome %></a>
                <a class="font-label-md text-on-surface-variant hover:text-primary transition-colors" href="/about"><%= t.navStory %></a>
                <a class="font-label-md text-on-surface-variant hover:text-primary transition-colors" href="/menu"><%= t.navMenu %></a>
                <a class="font-label-md text-on-surface-variant hover:text-primary transition-colors" href="/reviews"><%= t.navReviews %></a>
                <a class="font-label-md text-on-surface-variant hover:text-primary transition-colors" href="/contact"><%= t.navContact %></a>
            </div>
            <div class="flex items-center gap-4">
                <!-- Language Switcher Button -->
                <a href="/lang/<%= lang === 'ar' ? 'en' : 'ar' %>" class="border border-primary text-primary px-3 py-1.5 rounded-lg font-label-md hover:bg-primary/5 active:scale-95 transition-all text-xs">
                    <%= t.langSwitchBtn %>
                </a>
            </div>
        </nav>
    </header>

    <main class="flex-grow">
        <!-- Hero Section -->
        <section class="pt-xl pb-lg px-gutter max-w-container-max mx-auto text-center">
            <h1 class="font-headline-xl text-headline-xl text-on-background mb-sm"><%= t.checkoutTitle %></h1>
            <p class="font-body-lg text-body-lg text-on-surface-variant max-w-2xl mx-auto"><%= t.checkoutSub %></p>
        </section>

        <!-- Checkout Section -->
        <section class="pb-xl max-w-container-max mx-auto px-gutter grid grid-cols-1 lg:grid-cols-12 gap-lg items-start">
            
            <!-- Checkout Form -->
            <div class="lg:col-span-7 bg-surface-container p-md rounded-xl border border-outline-variant/30 space-y-md">
                <h3 class="font-headline-md text-headline-md text-on-surface"><%= t.checkoutFormHeader %></h3>
                
                <div id="error-message" class="hidden bg-error-container text-on-error-container p-sm rounded-lg font-label-md border border-error/20"></div>

                <form id="checkout-form" onsubmit="submitOrder(event)" class="space-y-md">
                    <input type="hidden" name="cart_data" id="cart-data-input"/>

                    <!-- Personal Information -->
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-sm">
                        <div class="space-y-xs">
                            <label class="font-label-sm text-on-surface-variant block"><%= t.labelName %></label>
                            <input type="text" name="customer_name" required class="w-full bg-background border border-outline-variant/50 rounded-lg p-sm focus:outline-none focus:border-primary font-body-md"/>
                        </div>
                        <div class="space-y-xs">
                            <label class="font-label-sm text-on-surface-variant block"><%= lang === 'ar' ? 'Ø±Ù‚Ù… Ø§Ù„Ù‡Ø§ØªÙ (Ø§Ù„ÙˆØ§ØªØ³Ø§Ø¨) *' : 'Phone Number (WhatsApp) *' %></label>
                            <input type="tel" name="customer_phone" placeholder="<%= t.checkoutPhonePlaceholder %>" required class="w-full bg-background border border-outline-variant/50 rounded-lg p-sm focus:outline-none focus:border-primary font-body-md"/>
                        </div>
                    </div>

                    <!-- Fulfillment Selection -->
                    <div class="space-y-xs">
                        <label class="font-label-sm text-on-surface-variant block"><%= t.fulfillmentHeader %></label>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-sm">
                            <label class="flex items-center gap-3 p-4 bg-background border border-outline-variant/50 rounded-lg cursor-pointer hover:border-primary transition-colors">
                                <input type="radio" name="delivery_type" value="pickup" checked onchange="toggleAddressField(false)" class="text-primary focus:ring-primary"/>
                                <div>
                                    <span class="font-label-md text-on-surface block"><%= t.fulfillmentPickup %></span>
                                    <span class="text-xs text-on-surface-variant font-body-md"><%= t.fulfillmentPickupDesc %></span>
                                </div>
                            </label>
                            <label class="flex items-center gap-3 p-4 bg-background border border-outline-variant/50 rounded-lg cursor-pointer hover:border-primary transition-colors">
                                <input type="radio" name="delivery_type" value="delivery" onchange="toggleAddressField(true)" class="text-primary focus:ring-primary"/>
                                <div>
                                    <span class="font-label-md text-on-surface block"><%= t.fulfillmentDelivery %></span>
                                    <span class="text-xs text-on-surface-variant font-body-md"><%= t.fulfillmentDeliveryDesc %></span>
                                </div>
                            </label>
                        </div>
                    </div>

                    <!-- Address Field (Conditional) -->
                    <div id="address-container" class="hidden space-y-xs">
                        <label class="font-label-sm text-on-surface-variant block"><%= t.labelAddress %></label>
                        <textarea name="address" id="address-input" rows="3" placeholder="<%= t.placeholderAddress %>" class="w-full bg-background border border-outline-variant/50 rounded-lg p-sm focus:outline-none focus:border-primary font-body-md"></textarea>
                    </div>

                    <!-- Payment Selection -->
                    <div class="space-y-xs">
                        <label class="font-label-sm text-on-surface-variant block"><%= t.paymentHeader %></label>
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-sm">
                            <label class="flex items-center gap-2 p-3 bg-background border border-outline-variant/50 rounded-lg cursor-pointer hover:border-primary transition-colors">
                                <input type="radio" name="payment_method" value="cod" checked class="text-primary focus:ring-primary"/>
                                <span class="font-label-sm text-on-surface text-xs"><%= t.paymentCod %></span>
                            </label>
                            <label class="flex items-center gap-2 p-3 bg-background border border-outline-variant/50 rounded-lg cursor-pointer hover:border-primary transition-colors">
                                <input type="radio" name="payment_method" value="instapay" class="text-primary focus:ring-primary"/>
                                <span class="font-label-sm text-on-surface text-xs"><%= t.paymentInstapay %></span>
                            </label>
                            <label class="flex items-center gap-2 p-3 bg-background border border-outline-variant/50 rounded-lg cursor-pointer hover:border-primary transition-colors">
                                <input type="radio" name="payment_method" value="vodafone_cash" class="text-primary focus:ring-primary"/>
                                <span class="font-label-sm text-on-surface text-xs"><%= t.paymentVodafone %></span>
                            </label>
                        </div>
                    </div>

                    <button type="submit" class="w-full bg-primary text-on-primary font-label-md py-4 rounded-lg hover:bg-primary-container active:scale-[0.98] transition-all shadow-md">
                        <%= t.btnConfirmOrder %>
                    </button>
                </form>
            </div>

            <!-- Order Summary Card -->
            <div class="lg:col-span-5 bg-surface-container-low p-md rounded-xl border border-outline-variant/30 space-y-md">
                <h3 class="font-headline-md text-headline-md text-on-surface border-b border-outline-variant/20 pb-sm"><%= t.summaryHeader %></h3>
                
                <!-- Dynamic Items list -->
                <div id="summary-items" class="space-y-sm max-h-72 overflow-y-auto custom-scrollbar pr-1">
                    <!-- Javascript injected items -->
                </div>

                <!-- Fees -->
                <div class="pt-sm border-t border-outline-variant/20 space-y-xs font-body-md text-body-md">
                    <div class="flex justify-between text-on-surface-variant">
                        <span><%= t.summaryTotal %></span>
                        <span id="summary-items-total">0 EGP</span>
                    </div>
                    <div class="flex justify-between text-on-surface-variant">
                        <span><%= t.summaryDeliveryFee %></span>
                        <span id="summary-shipping"><%= t.deliveryFreePickup %></span>
                    </div>
                    <div class="flex justify-between text-on-surface font-bold text-lg pt-sm border-t border-outline-variant/10">
                        <span><%= t.summaryGrandTotal %></span>
                        <span id="summary-grand-total" class="text-primary">0 EGP</span>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <!-- Mobile Navigation Drawer -->
    <div id="mobile-drawer" class="fixed inset-y-0 <%= lang === 'ar' ? 'right-0' : 'left-0' %> w-72 bg-surface shadow-2xl z-[150] transform <%= lang === 'ar' ? 'translate-x-full' : '-translate-x-full' %> transition-transform duration-300 flex flex-col border-r border-outline-variant/30 font-body-md">
        <div class="p-md border-b border-outline-variant/30 flex justify-between items-center bg-surface-container-low">
            <img src="/images/logo/lockup.svg" alt="Hayla Logo" class="h-8 w-auto" />
            <button onclick="toggleMobileDrawer()" class="text-on-surface hover:text-primary">
                <span class="material-symbols-outlined text-[32px]">close</span>
            </button>
        </div>
        <div class="flex flex-col p-md space-y-sm text-lg font-label-md">
            <a class="py-sm border-b border-outline-variant/10 text-on-surface-variant hover:text-primary transition-colors flex items-center justify-between" href="/">
                <span><%= t.navHome %></span>
                <span class="material-symbols-outlined text-sm"><%= lang === 'ar' ? 'chevron_left' : 'chevron_right' %></span>
            </a>
            <a class="py-sm border-b border-outline-variant/10 text-on-surface-variant hover:text-primary transition-colors flex items-center justify-between" href="/about">
                <span><%= t.navStory %></span>
                <span class="material-symbols-outlined text-sm"><%= lang === 'ar' ? 'chevron_left' : 'chevron_right' %></span>
            </a>
            <a class="py-sm border-b border-outline-variant/10 text-on-surface-variant hover:text-primary transition-colors flex items-center justify-between" href="/menu">
                <span><%= t.navMenu %></span>
                <span class="material-symbols-outlined text-sm"><%= lang === 'ar' ? 'chevron_left' : 'chevron_right' %></span>
            </a>
            <a class="py-sm border-b border-outline-variant/10 text-on-surface-variant hover:text-primary transition-colors flex items-center justify-between" href="/reviews">
                <span><%= t.navReviews %></span>
                <span class="material-symbols-outlined text-sm"><%= lang === 'ar' ? 'chevron_left' : 'chevron_right' %></span>
            </a>
            <a class="py-sm border-b border-outline-variant/10 text-on-surface-variant hover:text-primary transition-colors flex items-center justify-between" href="/contact">
                <span><%= t.navContact %></span>
                <span class="material-symbols-outlined text-sm"><%= lang === 'ar' ? 'chevron_left' : 'chevron_right' %></span>
            </a>
            <div class="pt-md flex flex-col gap-sm">
                <a href="/lang/<%= lang === 'ar' ? 'en' : 'ar' %>" class="border border-primary text-primary px-4 py-2 rounded-lg font-label-md hover:bg-primary/5 transition-all text-sm text-center">
                    <%= t.langSwitchBtn %>
                </a>
                <a href="/menu" class="bg-primary text-on-primary px-4 py-2 rounded-lg font-label-md hover:bg-primary-container transition-all text-sm text-center">
                    <%= t.btnPreorder %>
                </a>
            </div>
        </div>
    </div>
    <!-- Backdrop for Mobile Drawer -->
    <div id="mobile-backdrop" onclick="toggleMobileDrawer()" class="fixed inset-0 bg-black/40 z-[140] hidden transition-opacity duration-300"></div>

    <!-- Footer -->
    <footer class="bg-surface-container-high border-t border-outline-variant/30 pt-xl pb-md">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-md px-gutter max-w-container-max mx-auto text-center md:text-left">
            <div>
                <img src="/images/logo/lockup.svg" alt="Hayla - Authentic Egyptian Homemade Food" class="h-10 md:h-12 w-auto mx-auto md:mx-0 mb-2" />
                <p class="font-body-md text-body-md text-on-surface-variant mb-6"><%= t.tagline %></p>
            </div>
            <div class="space-y-4">
                <h4 class="font-label-md text-on-surface font-bold uppercase tracking-widest"><%= lang === 'ar' ? 'Ø±ÙˆØ§Ø¨Ø· Ø³Ø±ÙŠØ¹Ø©' : 'Navigation' %></h4>
                <nav class="flex flex-col gap-2 font-body-md text-on-surface-variant">
                    <a class="hover:text-primary transition-all underline decoration-primary/30 underline-offset-4" href="/about"><%= t.navStory %></a>
                    <a class="hover:text-primary transition-all underline decoration-primary/30 underline-offset-4" href="/menu"><%= t.navMenu %></a>
                    <a class="hover:text-primary transition-all underline decoration-primary/30 underline-offset-4" href="/contact"><%= t.navContact %></a>
                </nav>
            </div>
            <div class="space-y-4">
                <h4 class="font-label-md text-on-surface font-bold uppercase tracking-widest">Connect</h4>
                <nav class="flex flex-col gap-2 font-body-md text-on-surface-variant">
                    <a class="hover:text-primary transition-all underline decoration-primary/30 underline-offset-4" href="<%= getWhatsappLink(settings.whatsapp_number) %>">WhatsApp</a>
                </nav>
            </div>
        </div>
        <div class="max-w-container-max mx-auto px-gutter mt-xl pt-md border-t border-outline-variant/20 text-center">
            <p class="font-body-md text-body-md text-on-surface-variant/70">Â© 2024 <%= t.brandName %>. <%= t.tagline %>.</p>
        </div>
    </footer>

    <!-- Checkout logic -->
    <script>
        function toggleMobileDrawer() {
            const drawer = document.getElementById('mobile-drawer');
            const backdrop = document.getElementById('mobile-backdrop');
            const isRtlDir = "<%= t.dir %>" === "rtl";
            const isOpen = isRtlDir
                ? !drawer.classList.contains('translate-x-full')
                : !drawer.classList.contains('-translate-x-full');
            if (isOpen) {
                drawer.classList.add(isRtlDir ? 'translate-x-full' : '-translate-x-full');
                backdrop.classList.add('hidden');
            } else {
                drawer.classList.remove(isRtlDir ? 'translate-x-full' : '-translate-x-full');
                backdrop.classList.remove('hidden');
            }
        }

        let cart = [];
        const isRtl = "<%= t.dir %>" === "rtl";

        document.addEventListener('DOMContentLoaded', () => {
            const savedCart = localStorage.getItem('hayla_cart');
            if (savedCart) {
                try {
                    cart = JSON.parse(savedCart);
                } catch(e) {
                    cart = [];
                }
            }
            if (cart.length === 0) {
                window.location.href = '/menu';
                return;
            }
            
            document.getElementById('cart-data-input').value = JSON.stringify(cart);
            renderSummary();
        });

        function toggleAddressField(show) {
            const container = document.getElementById('address-container');
            const input = document.getElementById('address-input');
            const shippingSpan = document.getElementById('summary-shipping');
            
            if (show) {
                container.classList.remove('hidden');
                input.required = true;
                shippingSpan.innerText = '50 EGP';
            } else {
                container.classList.add('hidden');
                input.required = false;
                input.value = '';
                shippingSpan.innerText = isRtl ? 'Ù…Ø¬Ø§Ù†Ø§Ù‹ (Ø§Ø³ØªÙ„Ø§Ù…)' : 'Free (Pickup)';
            }
            
            recalculateGrandTotal();
        }

        function renderSummary() {
            const container = document.getElementById('summary-items');
            container.innerHTML = '';
            
            let total = 0;
            
            cart.forEach(item => {
                total += item.price * item.quantity;
                
                const div = document.createElement('div');
                div.className = 'flex justify-between items-center text-sm font-body-md py-1 border-b border-outline-variant/10';
                div.innerHTML = `
                    <span class="text-on-surface-variant">${item.name} <span class="font-bold">x ${item.quantity}</span></span>
                    <span class="text-on-surface font-semibold">${item.price * item.quantity} EGP</span>
                `;
                container.appendChild(div);
            });

            document.getElementById('summary-items-total').innerText = total + ' EGP';
            recalculateGrandTotal();
        }

        function recalculateGrandTotal() {
            let total = 0;
            cart.forEach(item => total += item.price * item.quantity);
            
            const isDelivery = document.querySelector('input[name="delivery_type"]:checked').value === 'delivery';
            const shipping = isDelivery ? 50 : 0;
            
            document.getElementById('summary-grand-total').innerText = (total + shipping) + ' EGP';
        }

        async function submitOrder(e) {
            e.preventDefault();
            
            const form = document.getElementById('checkout-form');
            const formData = new FormData(form);
            
            const payload = {};
            formData.forEach((value, key) => payload[key] = value);
            
            // Add cart data
            payload.cart_data = JSON.stringify(cart);

            const errDiv = document.getElementById('error-message');
            errDiv.classList.add('hidden');

            try {
                const response = await fetch('/checkout', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                
                const result = await response.json();
                
                if (result.success) {
                    localStorage.removeItem('hayla_cart');
                    window.location.href = '/confirmation?orderId=' + result.orderId;
                } else {
                    errDiv.innerText = result.error || (isRtl ? 'Ø­Ø¯Ø« Ø®Ø·Ø£ ØºÙŠØ± Ù…ØªÙˆÙ‚Ø¹. ÙŠØ±Ø¬Ù‰ Ø§Ù„Ù…Ø­Ø§ÙˆÙ„Ø© Ù…Ø±Ø© Ø£Ø®Ø±Ù‰.' : 'An unexpected error occurred. Please try again.');
                    errDiv.classList.remove('hidden');
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                }
            } catch(err) {
                errDiv.innerText = isRtl ? 'ÙØ´Ù„ Ø§Ù„Ø§ØªØµØ§Ù„ Ø¨Ø§Ù„Ø®Ø§Ø¯Ù…. ÙŠØ±Ø¬Ù‰ Ø§Ù„ØªØ­Ù‚Ù‚ Ù…Ù† Ø§ØªØµØ§Ù„Ùƒ Ø¨Ø§Ù„Ø¥Ù†ØªØ±Ù†Øª.' : 'Connection to the server failed. Please check your internet connection.';
                errDiv.classList.remove('hidden');
                window.scrollTo({ top: 0, behavior: 'smooth' });
            }
        }
    </script>
</body>
</html>

