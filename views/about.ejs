<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= t.dir %>" class="scroll-smooth">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title><%= t.brandName %> - <%= t.navStory %></title>
    <link rel="icon" type="image/svg+xml" href="/images/logo/icon.svg" />
    <link rel="apple-touch-icon" href="/images/logo/icon.svg" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&amp;family=Quicksand:wght@400;500;600;700&amp;family=Cairo:wght@400;600;700;750&amp;display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
    <script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            "colors": {
              "primary-container": "#b8583d",
              "on-background": "#1d1c18",
              "surface-container-high": "#ece7e1",
              "on-secondary-fixed": "#291800",
              "surface": "#fef9f2",
              "secondary-fixed-dim": "#fabb57",
              "error-container": "#ffdad6",
              "on-error": "#ffffff",
              "on-surface-variant": "#56423d",
              "secondary-fixed": "#ffddb0",
              "on-secondary-fixed-variant": "#614000",
              "tertiary-fixed-dim": "#b7cda8",
              "on-secondary": "#ffffff",
              "on-secondary-container": "#734d00",
              "surface-variant": "#e6e2db",
              "on-primary-fixed-variant": "#7d2c14",
              "tertiary": "#4e6143",
              "on-tertiary-container": "#f8ffee",
              "inverse-on-surface": "#f5f0e9",
              "secondary-container": "#fdbe5a",
              "on-primary-fixed": "#3b0900",
              "surface-dim": "#ded9d3",
              "surface-container-highest": "#e6e2db",
              "on-primary": "#ffffff",
              "on-tertiary-fixed": "#0f2008",
              "on-surface": "#1d1c18",
              "secondary": "#805600",
              "surface-tint": "#9c4329",
              "error": "#ba1a1a",
              "on-primary-container": "#fffbff",
              "primary": "#994127",
              "tertiary-container": "#667a5a",
              "primary-fixed-dim": "#ffb5a0",
              "outline-variant": "#dcc1ba",
              "primary-fixed": "#ffdbd1",
              "on-tertiary": "#ffffff",
              "on-error-container": "#93000a",
              "background": "#fef9f2",
              "inverse-surface": "#32302c",
              "outline": "#89726c",
              "surface-bright": "#fef9f2",
              "on-tertiary-fixed-variant": "#394c2f",
              "tertiary-fixed": "#d3e9c3",
              "surface-container-lowest": "#ffffff",
              "inverse-primary": "#ffb5a0",
              "surface-container-low": "#f8f3ec",
              "surface-container": "#f2ede6"
            },
            "borderRadius": {
              "DEFAULT": "0.25rem",
              "lg": "0.5rem",
              "xl": "0.75rem",
              "full": "9999px"
            },
            "spacing": {
              "xs": "4px",
              "gutter": "24px",
              "sm": "12px",
              "lg": "48px",
              "md": "24px",
              "base": "8px",
              "container-max": "1200px",
              "xl": "80px"
            },
            "fontFamily": {
              "body-lg": ["<%= lang === 'ar' ? 'Cairo' : 'Quicksand' %>", "sans-serif"],
              "body-md": ["<%= lang === 'ar' ? 'Cairo' : 'Quicksand' %>", "sans-serif"],
              "headline-lg": ["<%= lang === 'ar' ? 'Cairo' : 'Playfair Display' %>", "serif"],
              "headline-md": ["<%= lang === 'ar' ? 'Cairo' : 'Playfair Display' %>", "serif"],
              "headline-lg-mobile": ["<%= lang === 'ar' ? 'Cairo' : 'Playfair Display' %>", "serif"],
              "label-md": ["<%= lang === 'ar' ? 'Cairo' : 'Quicksand' %>", "sans-serif"],
              "label-sm": ["<%= lang === 'ar' ? 'Cairo' : 'Quicksand' %>", "sans-serif"],
              "headline-xl": ["<%= lang === 'ar' ? 'Cairo' : 'Playfair Display' %>", "serif"]
            }
          },
        },
      }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .linen-texture {
            position: fixed;
            inset: 0;
            z-index: -1;
            opacity: 0.03;
            pointer-events: none;
            background-image: url("https://www.transparenttextures.com/patterns/linen-design.png");
        }
        .brush-underline {
            position: relative;
            display: inline-block;
        }
        .brush-underline::after {
            content: '';
            position: absolute;
            bottom: -4px;
            left: 0;
            width: 100%;
            height: 8px;
            background: #994127;
            opacity: 0.2;
            mask-image: url('data:image/svg+xml;utf8,<svg viewBox="0 0 100 20" xmlns="http://www.w3.org/2000/svg"><path d="M0 10 Q 25 5, 50 10 T 100 10" stroke="black" stroke-width="5" fill="none" /></svg>');
            mask-size: cover;
            transform: scaleX(0);
            transition: transform 0.3s ease;
            transform-origin: left;
        }
        .brush-underline:hover::after {
            transform: scaleX(1);
        }
    </style>
    <style>
        body {
            min-height: max(884px, 100dvh);
        }
    </style>
</head>
<body class="bg-background text-on-background selection:bg-primary-fixed selection:text-on-primary-fixed">
    <div class="linen-texture"></div>
    
    <!-- TopAppBar -->
    <header class="sticky top-0 w-full z-50 bg-surface/90 backdrop-blur-md shadow-sm">
        <nav class="flex justify-between items-center h-20 px-gutter max-w-container-max mx-auto">
            <div class="flex items-center gap-4">
                <span class="material-symbols-outlined text-primary text-2xl active:scale-95 duration-200">menu</span>
                <a href="/" class="flex items-center">
                    <img src="/images/logo/lockup.svg" alt="Hayla - Authentic Egyptian Homemade Food" class="h-10 md:h-12 w-auto" />
                </a>
            </div>
            <div class="hidden md:flex gap-8 items-center">
                <a class="font-label-md text-on-surface-variant hover:text-primary transition-colors" href="/"><%= t.navHome %></a>
                <a class="font-label-md text-primary border-b-2 border-primary" href="/about"><%= t.navStory %></a>
                <a class="font-label-md text-on-surface-variant hover:text-primary transition-colors" href="/menu"><%= t.navMenu %></a>
                <a class="font-label-md text-on-surface-variant hover:text-primary transition-colors" href="/reviews"><%= t.navReviews %></a>
                <a class="font-label-md text-on-surface-variant hover:text-primary transition-colors" href="/contact"><%= t.navContact %></a>
            </div>
            <div class="flex items-center gap-4">
                <!-- Language Switcher Button -->
                <a href="/lang/<%= lang === 'ar' ? 'en' : 'ar' %>" class="border border-primary text-primary px-3 py-1.5 rounded-lg font-label-md hover:bg-primary/5 active:scale-95 transition-all text-xs">
                    <%= t.langSwitchBtn %>
                </a>
                <a href="/menu" class="bg-primary text-on-primary px-6 py-2.5 rounded-lg font-label-md active:scale-95 duration-200 shadow-sm hover:bg-primary-container transition-all text-center">
                    <%= t.btnPreorder %>
                </a>
            </div>
        </nav>
    </header>

    <main>
        <!-- Hero Section -->
        <section class="relative pt-xl pb-lg overflow-hidden">
            <div class="max-w-container-max mx-auto px-gutter grid grid-cols-1 md:grid-cols-12 gap-lg items-center">
                <div class="md:col-span-5 order-2 md:order-1">
                    <span class="inline-block px-4 py-1.5 rounded-full bg-secondary-fixed text-on-secondary-fixed font-label-sm mb-6">Since 1984</span>
                    <h1 class="font-headline-xl text-headline-xl mb-6 text-on-background"><%= lang === 'ar' ? 'الروح وراء' : 'The Soul Behind' %> <span class="text-primary"><%= t.brandName %></span></h1>
                    <p class="font-body-lg text-body-lg text-on-surface-variant mb-8 max-w-lg">
                        <%= lang === 'ar' ? 'تعرف على الشيف أميرة، التي حولت شغفها بالضيافة المصرية التقليدية إلى حركة تحتفي بفن الوجبة البيتي.' : 'Meet Chef Amira, who turned her passion for traditional Egyptian hospitality into a movement that celebrates the art of the homemade meal.' %>
                    </p>
                    <div class="flex items-center gap-4">
                        <div class="w-12 h-[1px] bg-outline-variant"></div>
                        <p class="font-label-md italic text-primary">"<%= lang === 'ar' ? 'الأكل هو الجسر الواصل بين الأجيال.' : 'Food is the bridge between generations.' %>"</p>
                    </div>
                </div>
                <div class="md:col-span-7 order-1 md:order-2">
                    <div class="relative rounded-xl overflow-hidden shadow-[0_20px_50px_rgba(192,94,66,0.1)]">
                        <img class="w-full aspect-[4/3] object-cover rounded-xl transition-transform duration-700 hover:scale-105" data-alt="Chef Amira in the kitchen" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDXcOZ2feUYPJDQ41zh5VmipxThj6IpuCQzBeHPwB-rCABjiA6vzrJd9DupxZbdZvewtQh9g8YSMs7c6CbdPvWZTECbhW8md8eXE19E0jYKFg7ZQ3ARqCYtZ1hlRLjyDe0ZfswacY7s71eRTPhMiPKLNz-xiEH9ywymc_i9W7H7UanE-FFB83iLKR7SvC5Dh5FSM4vYve-T3GV30bYWFdCf4cCZOajWQEbulV9x27Cv9Fl16sMDBOsoUDkU-bf50AuPRpsWueArSnvJ"/>
                        <div class="absolute inset-0 ring-1 ring-inset ring-black/5 rounded-xl"></div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Story Section -->
        <section class="bg-surface-container-low py-xl">
            <div class="max-w-container-max mx-auto px-gutter">
                <div class="text-center mb-xl">
                    <h2 class="font-headline-lg text-headline-lg mb-4"><%= t.storyTitle %></h2>
                    <div class="w-24 h-1 bg-primary mx-auto rounded-full opacity-30"></div>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-xl items-center">
                    <div class="space-y-6">
                        <p class="font-body-lg text-body-lg text-on-surface-variant">
                            <%= t.storyDesc %>
                        </p>
                        <div class="pt-4">
                            <a class="brush-underline font-label-md text-primary uppercase tracking-widest" href="/menu"><%= t.storyLink %></a>
                        </div>
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div class="space-y-4 pt-12">
                            <img class="w-full aspect-square object-cover rounded-lg shadow-sm" data-alt="Kneading dough" src="https://lh3.googleusercontent.com/aida-public/AB6AXuD1_IRe5TzBIygUBTpFcSbapOqDvFrm-ouTSrIjQ1FWg_csw8_s-IkigoQrfJY0JRncijgRC6rzpwWsiiZ7B3rEChQgL4zqknF6mrBFD0cV6lE1Lje5uC5WgWNtWiEs1sQEm3ThN-v5nyA3YsE5pZjI3wrbk9CoLEae4QBLCGlwvbEy_71S0BYyjb7IDWIjW4yfHXHddB6Gw7I3AH_YyYtT-EGbP40yJzwcCqbuHr3SottwG6fAyicaRI4UAk2t_EZJOgPBLtkHXW2V"/>
                            <img class="w-full aspect-square object-cover rounded-lg shadow-sm" data-alt="Mezze platter" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDoyszgleJ2eZPTwS5Z1buIP8Ny2heZ10Xt1CMDhKnBV57GclqCeNKDkLfYKxufCgBFWDA4PiAWD2vTegol7dvI31COHP1zacUqMPd79tXvmcz-tDk63-tUNR1qRy1q6fB8Ez-X34hHmehQRVceinBtZEMaLMjzeKwp3h82Ruh_XbKNtkuXUoIe9-qljHpujbmKEKWj8lBDWSgMs_uR6KNI7XZDUatGIsYImQKrHBx6gggxLJS69RjIB92OokGP_quGMJAsW7yOEn_T"/>
                        </div>
                        <div class="space-y-4">
                            <img class="w-full aspect-square object-cover rounded-lg shadow-sm" data-alt="Spices and mortar" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAorh7fAuKbglmlMMU38bf6PzjNTR8WJU202wq8BLfPjyU2gdbwz15eWHBxeTNpnPSO7JZXSlMK9Lmjxux_piazO4DErbhYqZ8KDrGBgrH4BeCMP2fcB9eHhAJ9_9aTKU9Ybo_hSKdeF6ywaRNdekIb0EZQDkRivqsL0LDKIiLKtgJmcXzOpxQt-1xwIY08VsQoHzSS0j3XUhT2n72PX9ltKHmg_ahPRH-JDmUQSFgwH-2vWIlET6UPG2f6Eb24HmfwmEMoI9MV3Rm7"/>
                            <img class="w-full aspect-square object-cover rounded-lg shadow-sm" data-alt="People eating" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCUys7m3qX9lWS9sGnrFLXLy3ENBmJ2tywMG6pWQP28r0u_HNwaOL-oheZjCBjE_F160SWKhdx5VTQhM0Nf0bP-5GNHQKFePpYWciAm6iQl25x6N7XazImYNa5JXGDgbYrrJWh8xlLKGQ_fGnunOMStxrKNBFvenjXvPbffiESe1gUuQBXNoZv3NKmXwF0w_0Xn-ydJDL1Em-cR1P-WN2vSgYHdC7kQ22imTCrS9gtc4ab-saO5WDJiVvQ7-9Q6qggn6V9ltZBi4RL5"/>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- What makes it Homemade? Section -->
        <section class="py-xl bg-surface">
            <div class="max-w-container-max mx-auto px-gutter">
                <div class="flex flex-col md:flex-row justify-between items-end mb-lg gap-6">
                    <div class="max-w-xl text-left">
                        <h2 class="font-headline-lg text-headline-lg mb-4"><%= lang === 'ar' ? 'إيه اللي بيخلي أكلنا بيتي بجد؟' : 'What makes it Homemade?' %></h2>
                        <p class="font-body-md text-body-md text-on-surface-variant"><%= lang === 'ar' ? 'بعيداً عن الوصفات السرية، إيقاع مطبخنا الهادئ هو اللي بيميزنا. بنرفض السرعة الصناعية عشان نضمن الجودة الحرفية.' : 'Beyond the recipes, it\'s the rhythm of our kitchen that defines us. We reject industrial speed in favor of artisanal patience.' %></p>
                    </div>
                    <a href="/menu" class="border-2 border-primary text-primary px-8 py-3 rounded-lg font-label-md hover:bg-primary/5 transition-colors text-center"><%= t.viewAllItems %></a>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-md">
                    <!-- Value 1 -->
                    <div class="bg-surface-container-lowest p-8 rounded-xl shadow-[0_4px_20px_-5px_rgba(192,94,66,0.05)] border border-outline-variant/20 hover:-translate-y-1 transition-transform duration-300">
                        <div class="w-14 h-14 bg-tertiary-fixed rounded-full flex items-center justify-center text-on-tertiary-fixed mb-6">
                            <span class="material-symbols-outlined text-3xl">local_mall</span>
                        </div>
                        <h3 class="font-headline-md text-headline-md mb-3"><%= lang === 'ar' ? 'مكونات بلدية طازجة' : 'Fresh Local Ingredients' %></h3>
                        <p class="font-body-md text-body-md text-on-surface-variant"><%= lang === 'ar' ? 'بنجيب خضارنا ولحومنا من المزارع المحلية كل يوم الصبح، عشان نضمن طعم بلدي طازة وغني.' : 'We source our produce from local Nile Delta farmers every morning, ensuring that every vegetable carries the peak flavor of the season.' %></p>
                    </div>
                    <!-- Value 2 -->
                    <div class="bg-surface-container-lowest p-8 rounded-xl shadow-[0_4px_20px_-5px_rgba(192,94,66,0.05)] border border-outline-variant/20 hover:-translate-y-1 transition-transform duration-300">
                        <div class="w-14 h-14 bg-secondary-fixed rounded-full flex items-center justify-center text-on-secondary-fixed mb-6">
                            <span class="material-symbols-outlined text-3xl">auto_stories</span>
                        </div>
                        <h3 class="font-headline-md text-headline-md mb-3"><%= lang === 'ar' ? 'وصفات متوارثة' : 'Traditional Recipes' %></h3>
                        <p class="font-body-md text-body-md text-on-surface-variant"><%= lang === 'ar' ? 'من غير اختصارات ولا مواد صناعية. بنستخدم نفس البهارات وطرق التسوية اللي أمهاتنا وجداتنا عودونا عليها.' : 'No shortcuts, no modern substitutes. We use the exact ratios of spices and slow-cooking times perfected by our grandmothers.' %></p>
                    </div>
                    <!-- Value 3 -->
                    <div class="bg-surface-container-lowest p-8 rounded-xl shadow-[0_4px_20px_-5px_rgba(192,94,66,0.05)] border border-outline-variant/20 hover:-translate-y-1 transition-transform duration-300">
                        <div class="w-14 h-14 bg-primary-fixed rounded-full flex items-center justify-center text-on-primary-fixed mb-6">
                            <span class="material-symbols-outlined text-3xl">restaurant</span>
                        </div>
                        <h3 class="font-headline-md text-headline-md mb-3"><%= lang === 'ar' ? 'الطبخ بحصص صغيرة' : 'Small Batch Cooking' %></h3>
                        <p class="font-body-md text-body-md text-on-surface-variant"><%= lang === 'ar' ? 'الطبخ بكميات صغيرة بيحافظ على روح ونكهة الأكل البيتي الأصلي. الشيف بتذوق وتظبط كل حلة بنفسها.' : 'By cooking in small quantities, we maintain the soul of the dish. Each pot is tasted and adjusted by our head chef personally.' %></p>
                    </div>
                </div>
            </div>
        </section>
    </main>

    <!-- Footer -->
    <footer class="bg-surface-container-high border-t border-outline-variant/30 pt-xl pb-md">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-md px-gutter max-w-container-max mx-auto text-center md:text-left">
            <div>
                <img src="/images/logo/lockup.svg" alt="Hayla - Authentic Egyptian Homemade Food" class="h-10 md:h-12 w-auto mx-auto md:mx-0 mb-2" />
                <p class="font-body-md text-body-md text-on-surface-variant mb-6"><%= t.tagline %></p>
            </div>
            <div class="space-y-4">
                <h4 class="font-label-md text-on-surface font-bold uppercase tracking-widest"><%= lang === 'ar' ? 'روابط سريعة' : 'Navigation' %></h4>
                <nav class="flex flex-col gap-2 font-body-md text-on-surface-variant">
                    <a class="hover:text-primary transition-all underline decoration-primary/30 underline-offset-4" href="/about"><%= t.navStory %></a>
                    <a class="hover:text-primary transition-all underline decoration-primary/30 underline-offset-4" href="/menu"><%= t.navMenu %></a>
                    <a class="hover:text-primary transition-all underline decoration-primary/30 underline-offset-4" href="/contact"><%= t.navContact %></a>
                </nav>
            </div>
            <div class="space-y-4">
                <h4 class="font-label-md text-on-surface font-bold uppercase tracking-widest">Connect</h4>
                <nav class="flex flex-col gap-2 font-body-md text-on-surface-variant">
                    <a class="hover:text-primary transition-all underline decoration-primary/30 underline-offset-4" href="https://wa.me/<%= settings.whatsapp_number ? settings.whatsapp_number.replace(/\D/g, '') : '' %>">WhatsApp</a>
                </nav>
            </div>
        </div>
        <div class="max-w-container-max mx-auto px-gutter mt-xl pt-md border-t border-outline-variant/20 text-center">
            <p class="font-body-md text-body-md text-on-surface-variant/70">© 2024 <%= t.brandName %>. <%= t.tagline %>.</p>
        </div>
    </footer>

    <script>
        const observerOptions = { threshold: 0.1 };
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('opacity-100', 'translate-y-0');
                    entry.target.classList.remove('opacity-0', 'translate-y-10');
                }
            });
        }, observerOptions);

        document.querySelectorAll('section > div').forEach(el => {
            el.classList.add('transition-all', 'duration-1000', 'opacity-0', 'translate-y-10');
            observer.observe(el);
        });
    </script>
</body>
</html>
