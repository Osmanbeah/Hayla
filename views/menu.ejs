<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= t.dir %>" class="scroll-smooth">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title><%= t.brandName %> - <%= t.navMenu %></title>
    <link rel="icon" type="image/svg+xml" href="/images/logo/icon.svg" />
    <link rel="apple-touch-icon" href="/images/logo/icon.svg" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&amp;family=Quicksand:wght@400;500;600;700&amp;family=Cairo:wght@400;600;700;750&amp;display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
    <script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            "colors": {
              "primary-container": "#b8583d",
              "on-background": "#1d1c18",
              "surface-container-high": "#ece7e1",
              "on-secondary-fixed": "#291800",
              "surface": "#fef9f2",
              "secondary-fixed-dim": "#fabb57",
              "error-container": "#ffdad6",
              "on-error": "#ffffff",
              "on-surface-variant": "#56423d",
              "secondary-fixed": "#ffddb0",
              "on-secondary-fixed-variant": "#614000",
              "tertiary-fixed-dim": "#b7cda8",
              "on-secondary": "#ffffff",
              "on-secondary-container": "#734d00",
              "surface-variant": "#e6e2db",
              "on-primary-fixed-variant": "#7d2c14",
              "tertiary": "#4e6143",
              "on-tertiary-container": "#f8ffee",
              "inverse-on-surface": "#f5f0e9",
              "secondary-container": "#fdbe5a",
              "on-primary-fixed": "#3b0900",
              "surface-dim": "#ded9d3",
              "surface-container-highest": "#e6e2db",
              "on-primary": "#ffffff",
              "on-tertiary-fixed": "#0f2008",
              "on-surface": "#1d1c18",
              "secondary": "#805600",
              "surface-tint": "#9c4329",
              "error": "#ba1a1a",
              "on-primary-container": "#fffbff",
              "primary": "#994127",
              "tertiary-container": "#667a5a",
              "primary-fixed-dim": "#ffb5a0",
              "outline-variant": "#dcc1ba",
              "primary-fixed": "#ffdbd1",
              "on-tertiary": "#ffffff",
              "on-error-container": "#93000a",
              "background": "#fef9f2",
              "inverse-surface": "#32302c",
              "outline": "#89726c",
              "surface-bright": "#fef9f2",
              "on-tertiary-fixed-variant": "#394c2f",
              "tertiary-fixed": "#d3e9c3",
              "surface-container-lowest": "#ffffff",
              "inverse-primary": "#ffb5a0",
              "surface-container-low": "#f8f3ec",
              "surface-container": "#f2ede6"
            },
            "borderRadius": {
              "DEFAULT": "0.25rem",
              "lg": "0.5rem",
              "xl": "0.75rem",
              "full": "9999px"
            },
            "spacing": {
              "xs": "4px",
              "gutter": "24px",
              "sm": "12px",
              "lg": "48px",
              "md": "24px",
              "base": "8px",
              "container-max": "1200px",
              "xl": "80px"
            },
            "fontFamily": {
              "body-lg": ["<%= lang === 'ar' ? 'Cairo' : 'Quicksand' %>", "sans-serif"],
              "body-md": ["<%= lang === 'ar' ? 'Cairo' : 'Quicksand' %>", "sans-serif"],
              "headline-lg": ["<%= lang === 'ar' ? 'Cairo' : 'Playfair Display' %>", "serif"],
              "headline-md": ["<%= lang === 'ar' ? 'Cairo' : 'Playfair Display' %>", "serif"],
              "headline-lg-mobile": ["<%= lang === 'ar' ? 'Cairo' : 'Playfair Display' %>", "serif"],
              "label-md": ["<%= lang === 'ar' ? 'Cairo' : 'Quicksand' %>", "sans-serif"],
              "label-sm": ["<%= lang === 'ar' ? 'Cairo' : 'Quicksand' %>", "sans-serif"],
              "headline-xl": ["<%= lang === 'ar' ? 'Cairo' : 'Playfair Display' %>", "serif"]
            }
          },
        },
      }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            vertical-align: middle;
        }
        .linen-texture {
            background-image: url("https://www.transparenttextures.com/patterns/linen.png");
            opacity: 0.03;
            pointer-events: none;
        }
        .brush-underline {
            position: relative;
            display: inline-block;
        }
        .brush-underline::after {
            content: '';
            position: absolute;
            bottom: -4px;
            left: 0;
            width: 0;
            height: 3px;
            background: #994127;
            border-radius: 50%;
            transition: width 0.3s ease;
        }
        .brush-underline:hover::after {
            width: 100%;
        }
        .food-card-shadow {
            box-shadow: 0 10px 30px -10px rgba(192, 94, 66, 0.12);
        }
    </style>
    <style>
        body {
            min-height: max(884px, 100dvh);
        }
    </style>
</head>
<body class="bg-surface text-on-background font-body-md antialiased min-h-screen flex flex-col relative">
    <div class="fixed inset-0 linen-texture pointer-events-none" style="z-index:-1"></div>
    
    <!-- TopAppBar -->
    <header class="sticky top-0 w-full z-50 bg-surface/90 backdrop-blur-md shadow-sm">
        <div class="flex justify-between items-center h-20 px-gutter max-w-container-max mx-auto">
            <div class="flex items-center gap-md">
                <button type="button" onclick="toggleMobileDrawer()" style="background:none;border:none;padding:8px;cursor:pointer;touch-action:manipulation;-webkit-tap-highlight-color:transparent"><span class="material-symbols-outlined" style="font-size:28px;color:var(--tw-primary,#b8583d);user-select:none">menu</span></button>
                <a href="/" class="flex items-center">
                    <img src="/images/logo/lockup.svg" alt="Hayla - Authentic Egyptian Homemade Food" class="h-10 md:h-12 w-auto" />
                </a>
            </div>
            <nav class="hidden md:flex gap-lg items-center">
                <a class="font-label-md text-label-md text-on-surface-variant hover:text-primary transition-colors" href="/"><%= t.navHome %></a>
                <a class="font-label-md text-label-md text-on-surface-variant hover:text-primary transition-colors" href="/about"><%= t.navStory %></a>
                <a class="font-label-md text-label-md text-primary border-b-2 border-primary transition-colors" href="/menu"><%= t.navMenu %></a>
                <a class="font-label-md text-label-md text-on-surface-variant hover:text-primary transition-colors" href="/reviews"><%= t.navReviews %></a>
                <a class="font-label-md text-label-md text-on-surface-variant hover:text-primary transition-colors" href="/contact"><%= t.navContact %></a>
            </nav>
            <div class="flex items-center gap-4">
                <!-- Language Switcher Button -->
                <a href="/lang/<%= lang === 'ar' ? 'en' : 'ar' %>" class="border border-primary text-primary px-3 py-1.5 rounded-lg font-label-md hover:bg-primary/5 active:scale-95 transition-all text-xs">
                    <%= t.langSwitchBtn %>
                </a>
                <button onclick="toggleCartDrawer()" class="relative bg-primary hover:bg-primary-container text-on-primary font-label-md text-label-md px-md py-xs rounded-lg shadow-sm active:scale-95 duration-200 flex items-center gap-2">
                    <span class="material-symbols-outlined">shopping_basket</span>
                    <span><%= t.cartTitle.split(' ')[0] %></span>
                    <span id="cart-badge" class="hidden absolute -top-2 -right-2 bg-secondary text-white text-xs font-bold w-5 h-5 rounded-full flex items-center justify-center">0</span>
                </button>
            </div>
        </div>
    </header>

    <main class="flex-grow">
        <!-- Hero Section -->
        <section class="pt-xl pb-lg px-gutter max-w-container-max mx-auto text-center">
            <h1 class="font-headline-xl text-headline-xl text-on-surface mb-md"><%= t.navMenu %></h1>
            <!-- Deadline Note -->
            <div class="inline-block bg-secondary-fixed text-on-secondary-fixed-variant px-lg py-md rounded-xl border border-secondary-container/50 food-card-shadow">
                <div class="flex items-center justify-center gap-xs">
                    <span class="material-symbols-outlined text-secondary">schedule</span>
                    <span class="font-label-md text-label-md">
                        <%= lang === 'ar' ? 'يغلق باب الحجز' : 'Orders close' %> <%= lang === 'ar' ? settings.deadline_day_ar : settings.deadline_day %> <%= lang === 'ar' ? 'الساعة' : 'at' %> <%= lang === 'ar' ? settings.deadline_time_ar : settings.deadline_time %> <%= lang === 'ar' ? 'للتسليم يوم' : 'for' %> <%= lang === 'ar' ? settings.delivery_date_ar : settings.delivery_date %>.
                    </span>
                </div>
            </div>
        </section>

        <!-- Menu Grid -->
        <section class="pb-xl px-gutter max-w-container-max mx-auto">
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-md">
                <% dishes.forEach((dish) => { %>
                    <div class="bg-surface-container-low rounded-lg overflow-hidden border border-outline-variant/30 flex flex-col group transition-all duration-300 hover:-translate-y-1 food-card-shadow">
                        <div class="h-[240px] overflow-hidden relative">
                            <img class="w-full h-full object-cover rounded-xl p-xs" data-alt="<%= dish.name %>" src="<%= dish.photo_url %>"/>
                            
                            <!-- Badges -->
                            <div class="absolute top-sm <%= lang === 'ar' ? 'left-sm' : 'right-sm' %> flex flex-col gap-2">
                                <% if (dish.is_chef_special) { %>
                                    <span class="bg-secondary-container text-on-secondary-container px-sm py-1 rounded-full text-label-sm font-label-sm uppercase tracking-wider"><%= t.chefSpecial %></span>
                                <% } %>
                                <% if (dish.is_vegetarian) { %>
                                    <span class="bg-tertiary-container text-on-tertiary-container px-sm py-1 rounded-full text-label-sm font-label-sm uppercase tracking-wider"><%= t.vegetarian %></span>
                                <% } %>
                            </div>

                            <% if (dish.stock_limit !== -1) { %>
                                <span class="absolute bottom-4 <%= lang === 'ar' ? 'left-4' : 'right-4' %> bg-surface/90 text-on-surface px-3 py-1 rounded-full text-label-sm font-bold shadow-sm">
                                    <%= t.limitedPortions %>: <%= dish.stock_limit %>
                                </span>
                            <% } %>
                        </div>
                        
                        <div class="p-md flex flex-col flex-grow">
                            <div class="flex justify-between items-start mb-xs">
                                <h3 class="font-headline-md text-headline-md text-on-surface"><%= dish.name %></h3>
                                <span class="font-label-md text-label-md text-primary font-bold"><%= dish.price %> EGP</span>
                            </div>
                            <p class="font-body-md text-body-md text-on-surface-variant mb-md flex-grow leading-relaxed"><%= dish.description %></p>
                            
                            <div class="flex items-center justify-between mt-auto pt-sm border-t border-outline-variant/20">
                                <% if (dish.is_available) { %>
                                    <!-- Quantity selector and Add Button -->
                                    <div class="flex items-center gap-2">
                                        <button onclick="changeQty('<%= dish.id %>', -1)" class="w-8 h-8 rounded-full border border-outline text-on-surface flex items-center justify-center font-bold active:scale-90">-</button>
                                        <span id="qty-<%= dish.id %>" class="font-label-md w-6 text-center">1</span>
                                        <button onclick="changeQty('<%= dish.id %>', 1)" class="w-8 h-8 rounded-full border border-outline text-on-surface flex items-center justify-center font-bold active:scale-90">+</button>
                                    </div>
                                    <button onclick="addToCart('<%= dish.id %>', '<%= dish.name %>', <%= dish.price %>)" class="bg-primary text-on-primary font-label-md text-label-md px-4 py-2 rounded-lg hover:bg-primary-container transition-colors flex items-center gap-1 active:scale-95">
                                        <%= t.addToCart %> <span class="material-symbols-outlined text-[18px]">shopping_cart</span>
                                    </button>
                                <% } else { %>
                                    <span class="text-error font-bold font-label-md"><%= t.soldOut %></span>
                                <% } %>
                            </div>
                        </div>
                    </div>
                <% }) %>

                <!-- Custom Request Card -->
                <div class="bg-primary/5 rounded-lg border-2 border-dashed border-primary/20 flex flex-col items-center justify-center p-xl text-center food-card-shadow">
                    <span class="material-symbols-outlined text-primary text-[48px] mb-md">restaurant_menu</span>
                    <h3 class="font-headline-md text-headline-md text-on-surface mb-xs"><%= t.cravingElse %></h3>
                    <p class="font-body-md text-body-md text-on-surface-variant mb-lg max-w-[240px]"><%= t.customRequestDesc %></p>
                    <a href="/contact" class="border-2 border-primary text-primary font-label-md text-label-md px-md py-xs rounded-lg hover:bg-primary hover:text-white transition-all active:scale-95 text-center">
                        <%= t.contactKitchen %>
                    </a>
                </div>
            </div>
        </section>
    </main>

    <!-- Cart Sidebar Drawer -->
    <div id="cart-drawer" class="fixed inset-y-0 <%= lang === 'ar' ? 'left-0' : 'right-0' %> w-full sm:w-96 bg-surface shadow-2xl z-[150] transform <%= lang === 'ar' ? '-translate-x-full' : 'translate-x-full' %> transition-transform duration-300 flex flex-col border-l border-outline-variant/30">
        <div class="p-md border-b border-outline-variant/30 flex justify-between items-center bg-surface-container-low">
            <div class="flex items-center gap-2 text-primary">
                <span class="material-symbols-outlined">shopping_basket</span>
                <h3 class="font-headline-md text-headline-md font-bold"><%= t.cartTitle %></h3>
            </div>
            <button onclick="toggleCartDrawer()" class="text-on-surface hover:text-primary">
                <span class="material-symbols-outlined text-[32px]">close</span>
            </button>
        </div>
        
        <!-- Cart Items List -->
        <div id="cart-items-container" class="flex-grow p-md overflow-y-auto space-y-md custom-scrollbar">
            <!-- Dynamic Cart Items Injection -->
        </div>

        <div class="p-md border-t border-outline-variant/30 bg-surface-container-low space-y-md">
            <div class="flex justify-between items-center">
                <span class="font-label-md text-on-surface-variant"><%= t.cartTotal %></span>
                <span id="cart-total" class="font-headline-md text-primary font-bold">0 EGP</span>
            </div>
            <a href="/checkout" class="w-full block bg-primary text-on-primary text-center font-label-md py-3 rounded-lg shadow-md hover:bg-primary-container active:scale-[0.98] transition-all">
                <%= t.cartCheckout %>
            </a>
        </div>
    </div>

    <!-- Backdrop for Drawer -->
    <div id="cart-backdrop" onclick="toggleCartDrawer()" class="fixed inset-0 bg-black/40 z-[140] hidden transition-opacity duration-300"></div>

    <!-- Mobile Navigation Drawer -->
    <div id="mobile-drawer" class="fixed inset-y-0 <%= lang === 'ar' ? 'right-0' : 'left-0' %> w-72 bg-surface shadow-2xl z-[150] transform <%= lang === 'ar' ? 'translate-x-full' : '-translate-x-full' %> transition-transform duration-300 flex flex-col border-r border-outline-variant/30 font-body-md">
        <div class="p-md border-b border-outline-variant/30 flex justify-between items-center bg-surface-container-low">
            <img src="/images/logo/lockup.svg" alt="Hayla Logo" class="h-8 w-auto" />
            <button onclick="toggleMobileDrawer()" class="text-on-surface hover:text-primary">
                <span class="material-symbols-outlined text-[32px]">close</span>
            </button>
        </div>
        <div class="flex flex-col p-md space-y-sm text-lg font-label-md">
            <a class="py-sm border-b border-outline-variant/10 text-on-surface-variant hover:text-primary transition-colors flex items-center justify-between" href="/">
                <span><%= t.navHome %></span>
                <span class="material-symbols-outlined text-sm"><%= lang === 'ar' ? 'chevron_left' : 'chevron_right' %></span>
            </a>
            <a class="py-sm border-b border-outline-variant/10 text-on-surface-variant hover:text-primary transition-colors flex items-center justify-between" href="/about">
                <span><%= t.navStory %></span>
                <span class="material-symbols-outlined text-sm"><%= lang === 'ar' ? 'chevron_left' : 'chevron_right' %></span>
            </a>
            <a class="py-sm border-b border-outline-variant/10 text-on-surface-variant hover:text-primary transition-colors flex items-center justify-between" href="/menu">
                <span><%= t.navMenu %></span>
                <span class="material-symbols-outlined text-sm"><%= lang === 'ar' ? 'chevron_left' : 'chevron_right' %></span>
            </a>
            <a class="py-sm border-b border-outline-variant/10 text-on-surface-variant hover:text-primary transition-colors flex items-center justify-between" href="/reviews">
                <span><%= t.navReviews %></span>
                <span class="material-symbols-outlined text-sm"><%= lang === 'ar' ? 'chevron_left' : 'chevron_right' %></span>
            </a>
            <a class="py-sm border-b border-outline-variant/10 text-on-surface-variant hover:text-primary transition-colors flex items-center justify-between" href="/contact">
                <span><%= t.navContact %></span>
                <span class="material-symbols-outlined text-sm"><%= lang === 'ar' ? 'chevron_left' : 'chevron_right' %></span>
            </a>
            
            <div class="pt-md flex flex-col gap-sm">
                <a href="/lang/<%= lang === 'ar' ? 'en' : 'ar' %>" class="border border-primary text-primary px-4 py-2 rounded-lg font-label-md hover:bg-primary/5 transition-all text-sm text-center">
                    <%= t.langSwitchBtn %>
                </a>
                <a href="/menu" class="bg-primary text-on-primary px-4 py-2 rounded-lg font-label-md hover:bg-primary-container transition-all text-sm text-center">
                    <%= t.btnPreorder %>
                </a>
            </div>
        </div>
    </div>
    
    <!-- Backdrop for Mobile Drawer -->
    <div id="mobile-backdrop" onclick="toggleMobileDrawer()" class="fixed inset-0 bg-black/40 z-[140] hidden transition-opacity duration-300"></div>

    <!-- Footer -->
    <footer class="bg-surface-container-high text-on-surface w-full pt-xl pb-md border-t border-outline-variant/30">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-md px-gutter max-w-container-max mx-auto text-center md:text-left">
            <div class="flex flex-col gap-sm">
                <img src="/images/logo/lockup.svg" alt="Hayla - Authentic Egyptian Homemade Food" class="h-10 md:h-12 w-auto mx-auto md:mx-0 mb-2" />
                <p class="font-body-md text-body-md text-on-surface-variant max-w-xs mx-auto md:mx-0">
                    <%= t.tagline %>
                </p>
            </div>
            <div class="flex flex-col gap-sm">
                <h4 class="font-label-md text-label-md uppercase tracking-widest text-on-surface mb-xs"><%= t.viewAllItems %></h4>
                <div class="flex flex-col gap-xs font-body-md text-body-md">
                    <a class="text-on-surface-variant hover:text-primary transition-all underline decoration-primary/30 underline-offset-4" href="/about"><%= t.navStory %></a>
                    <a class="text-primary font-bold transition-all underline decoration-primary/30 underline-offset-4" href="/menu"><%= t.navMenu %></a>
                    <a class="text-on-surface-variant hover:text-primary transition-all underline decoration-primary/30 underline-offset-4" href="/contact"><%= t.navContact %></a>
                </div>
            </div>
            <div class="flex flex-col gap-sm">
                <h4 class="font-label-md text-label-md uppercase tracking-widest text-on-surface mb-xs">Connect</h4>
                <div class="flex flex-col gap-xs font-body-md text-body-md">
                    <a class="text-on-surface-variant hover:text-primary transition-all underline decoration-primary/30 underline-offset-4 flex items-center justify-center md:justify-start gap-xs" href="<%= getWhatsappLink(settings.whatsapp_number) %>">
                        <span class="material-symbols-outlined text-[20px]">chat</span> WhatsApp
                    </a>
                </div>
            </div>
        </div>
        <div class="max-w-container-max mx-auto px-gutter mt-lg pt-md border-t border-outline-variant/20 text-center">
            <p class="font-body-md text-body-md text-on-surface-variant opacity-90">Â© 2024 <%= t.brandName %>. <%= t.tagline %>.</p>
        </div>
    </footer>

    <script>
        function toggleMobileDrawer() {
            const drawer = document.getElementById('mobile-drawer');
            const backdrop = document.getElementById('mobile-backdrop');
            const isRtl = "<%= t.dir %>" === "rtl";
            
            let isOpen = isRtl 
                ? !drawer.classList.contains('translate-x-full')
                : !drawer.classList.contains('-translate-x-full');

            if (isOpen) {
                if (isRtl) {
                    drawer.classList.add('translate-x-full');
                } else {
                    drawer.classList.add('-translate-x-full');
                }
                backdrop.classList.add('hidden');
            } else {
                if (isRtl) {
                    drawer.classList.remove('translate-x-full');
                } else {
                    drawer.classList.remove('-translate-x-full');
                }
                backdrop.classList.remove('hidden');
            }
        }

        let cart = [];
        const isRtl = "<%= t.dir %>" === "rtl";

        document.addEventListener('DOMContentLoaded', () => {
            const savedCart = localStorage.getItem('hayla_cart');
            if (savedCart) {
                try {
                    cart = JSON.parse(savedCart);
                } catch(e) {
                    cart = [];
                }
            }
            updateCartUI();

            const cards = document.querySelectorAll('.food-card-shadow');
            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        entry.target.style.opacity = '1';
                        entry.target.style.transform = 'translateY(0)';
                    }
                });
            }, { threshold: 0.1 });

            cards.forEach(card => {
                card.style.opacity = '0';
                card.style.transform = 'translateY(20px)';
                card.style.transition = 'all 0.6s ease-out';
                observer.observe(card);
            });
        });

        function changeQty(dishId, delta) {
            const qtySpan = document.getElementById('qty-' + dishId);
            if (!qtySpan) return;
            let current = parseInt(qtySpan.innerText);
            current += delta;
            if (current < 1) current = 1;
            qtySpan.innerText = current;
        }

        function addToCart(dishId, name, price) {
            const qtySpan = document.getElementById('qty-' + dishId);
            const qty = qtySpan ? parseInt(qtySpan.innerText) : 1;
            
            const existing = cart.find(item => item.id === dishId);
            if (existing) {
                existing.quantity += qty;
            } else {
                cart.push({ id: dishId, name, price, quantity: qty });
            }

            if (qtySpan) qtySpan.innerText = '1';

            localStorage.setItem('hayla_cart', JSON.stringify(cart));
            updateCartUI();
            toggleCartDrawer(true);
        }

        function removeFromCart(dishId) {
            cart = cart.filter(item => item.id !== dishId);
            localStorage.setItem('hayla_cart', JSON.stringify(cart));
            updateCartUI();
        }

        function toggleCartDrawer(forceOpen = null) {
            const drawer = document.getElementById('cart-drawer');
            const backdrop = document.getElementById('cart-backdrop');
            
            let isOpen = isRtl 
                ? !drawer.classList.contains('-translate-x-full')
                : !drawer.classList.contains('translate-x-full');

            if (forceOpen !== null) isOpen = !forceOpen;

            if (isOpen) {
                // Close
                if (isRtl) {
                    drawer.classList.add('-translate-x-full');
                } else {
                    drawer.classList.add('translate-x-full');
                }
                backdrop.classList.add('hidden');
            } else {
                // Open
                if (isRtl) {
                    drawer.classList.remove('-translate-x-full');
                } else {
                    drawer.classList.remove('translate-x-full');
                }
                backdrop.classList.remove('hidden');
            }
        }

        function updateCartUI() {
            const container = document.getElementById('cart-items-container');
            const totalSpan = document.getElementById('cart-total');
            const badge = document.getElementById('cart-badge');
            
            container.innerHTML = '';
            
            if (cart.length === 0) {
                container.innerHTML = `
                    <div class="text-center py-xl space-y-md opacity-60">
                        <span class="material-symbols-outlined text-[64px]">shopping_basket</span>
                        <p class="font-body-lg">${isRtl ? 'Ø³Ù„ØªÙƒ ÙØ§Ø±ØºØ© Ø­Ø§Ù„ÙŠØ§Ù‹' : 'Your cart is empty.'}</p>
                    </div>
                `;
                totalSpan.innerText = '0 EGP';
                badge.classList.add('hidden');
                badge.innerText = '0';
                return;
            }

            let total = 0;
            let totalQty = 0;

            cart.forEach(item => {
                total += item.price * item.quantity;
                totalQty += item.quantity;

                const itemDiv = document.createElement('div');
                itemDiv.className = 'flex justify-between items-center p-sm bg-surface-container-highest rounded-lg border border-outline-variant/35';
                itemDiv.innerHTML = `
                    <div class="flex-grow ${isRtl ? 'pl-sm' : 'pr-sm'} text-left">
                        <h4 class="font-label-md text-on-surface">${item.name}</h4>
                        <p class="text-sm text-on-surface-variant font-body-md">${item.quantity} x ${item.price} EGP</p>
                    </div>
                    <div class="flex items-center gap-xs">
                        <span class="font-label-md text-primary font-bold">${item.price * item.quantity} EGP</span>
                        <button onclick="removeFromCart('${item.id}')" class="text-error/70 hover:text-error active:scale-90 ml-2">
                            <span class="material-symbols-outlined text-[20px]">delete</span>
                        </button>
                    </div>
                `;
                container.appendChild(itemDiv);
            });

            totalSpan.innerText = total + ' EGP';
            badge.classList.remove('hidden');
            badge.innerText = totalQty;
        }
    </script>
</body>
</html>


