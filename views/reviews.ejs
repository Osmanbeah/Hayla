<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= t.dir %>" class="scroll-smooth">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title><%= t.brandName %> - <%= t.navReviews %></title>
    <link rel="icon" type="image/svg+xml" href="/images/logo/icon.svg" />
    <link rel="apple-touch-icon" href="/images/logo/icon.svg" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&amp;family=Quicksand:wght@400;500;600;700&amp;family=Cairo:wght@400;600;700;750&amp;display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
    <script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            "colors": {
              "primary-container": "#b8583d",
              "on-background": "#1d1c18",
              "surface-container-high": "#ece7e1",
              "on-secondary-fixed": "#291800",
              "surface": "#fef9f2",
              "secondary-fixed-dim": "#fabb57",
              "error-container": "#ffdad6",
              "on-error": "#ffffff",
              "on-surface-variant": "#56423d",
              "secondary-fixed": "#ffddb0",
              "on-secondary-fixed-variant": "#614000",
              "tertiary-fixed-dim": "#b7cda8",
              "on-secondary": "#ffffff",
              "on-secondary-container": "#734d00",
              "surface-variant": "#e6e2db",
              "on-primary-fixed-variant": "#7d2c14",
              "tertiary": "#4e6143",
              "on-tertiary-container": "#f8ffee",
              "inverse-on-surface": "#f5f0e9",
              "secondary-container": "#fdbe5a",
              "on-primary-fixed": "#3b0900",
              "surface-dim": "#ded9d3",
              "surface-container-highest": "#e6e2db",
              "on-primary": "#ffffff",
              "on-tertiary-fixed": "#0f2008",
              "on-surface": "#1d1c18",
              "secondary": "#805600",
              "surface-tint": "#9c4329",
              "error": "#ba1a1a",
              "on-primary-container": "#fffbff",
              "primary": "#994127",
              "tertiary-container": "#667a5a",
              "primary-fixed-dim": "#ffb5a0",
              "outline-variant": "#dcc1ba",
              "primary-fixed": "#ffdbd1",
              "on-tertiary": "#ffffff",
              "on-error-container": "#93000a",
              "background": "#fef9f2",
              "inverse-surface": "#32302c",
              "outline": "#89726c",
              "surface-bright": "#fef9f2",
              "on-tertiary-fixed-variant": "#394c2f",
              "tertiary-fixed": "#d3e9c3",
              "surface-container-lowest": "#ffffff",
              "inverse-primary": "#ffb5a0",
              "surface-container-low": "#f8f3ec",
              "surface-container": "#f2ede6"
            },
            "borderRadius": {
              "DEFAULT": "0.25rem",
              "lg": "0.5rem",
              "xl": "0.75rem",
              "full": "9999px"
            },
            "spacing": {
              "xs": "4px",
              "gutter": "24px",
              "sm": "12px",
              "lg": "48px",
              "md": "24px",
              "base": "8px",
              "container-max": "1200px",
              "xl": "80px"
            },
            "fontFamily": {
              "body-lg": ["<%= lang === 'ar' ? 'Cairo' : 'Quicksand' %>", "sans-serif"],
              "body-md": ["<%= lang === 'ar' ? 'Cairo' : 'Quicksand' %>", "sans-serif"],
              "headline-lg": ["<%= lang === 'ar' ? 'Cairo' : 'Playfair Display' %>", "serif"],
              "headline-md": ["<%= lang === 'ar' ? 'Cairo' : 'Playfair Display' %>", "serif"],
              "headline-lg-mobile": ["<%= lang === 'ar' ? 'Cairo' : 'Playfair Display' %>", "serif"],
              "label-md": ["<%= lang === 'ar' ? 'Cairo' : 'Quicksand' %>", "sans-serif"],
              "label-sm": ["<%= lang === 'ar' ? 'Cairo' : 'Quicksand' %>", "sans-serif"],
              "headline-xl": ["<%= lang === 'ar' ? 'Cairo' : 'Playfair Display' %>", "serif"]
            }
          },
        },
      }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            vertical-align: middle;
        }
        .linen-texture {
            position: fixed;
            inset: 0;
            z-index: -1;
            opacity: 0.04;
            pointer-events: none;
            background-image: url("https://www.transparenttextures.com/patterns/linen.png");
        }
        .rating-star-fill {
            font-variation-settings: 'FILL' 1, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            color: #fdbe5a;
        }
    </style>
    <style>
        body {
            min-height: max(884px, 100dvh);
        }
    </style>
</head>
<body class="bg-background text-on-background font-body-md min-h-screen flex flex-col relative antialiased">
    <div class="linen-texture"></div>

    <!-- TopAppBar -->
    <header class="sticky top-0 w-full z-50 bg-surface/90 backdrop-blur-md shadow-sm">
        <nav class="flex justify-between items-center h-20 px-gutter max-w-container-max mx-auto">
            <div class="flex items-center gap-4">
                <span class="material-symbols-outlined text-primary text-2xl active:scale-95 duration-200">menu</span>
                <a href="/" class="flex items-center">
                    <img src="/images/logo/lockup.svg" alt="Hayla - Authentic Egyptian Homemade Food" class="h-10 md:h-12 w-auto" />
                </a>
            </div>
            <div class="hidden md:flex gap-8 items-center">
                <a class="font-label-md text-on-surface-variant hover:text-primary transition-colors" href="/"><%= t.navHome %></a>
                <a class="font-label-md text-on-surface-variant hover:text-primary transition-colors" href="/about"><%= t.navStory %></a>
                <a class="font-label-md text-on-surface-variant hover:text-primary transition-colors" href="/menu"><%= t.navMenu %></a>
                <a class="font-label-md text-primary border-b-2 border-primary" href="/reviews"><%= t.navReviews %></a>
                <a class="font-label-md text-on-surface-variant hover:text-primary transition-colors" href="/contact"><%= t.navContact %></a>
            </div>
            <div class="flex items-center gap-4">
                <!-- Language Switcher Button -->
                <a href="/lang/<%= lang === 'ar' ? 'en' : 'ar' %>" class="border border-primary text-primary px-3 py-1.5 rounded-lg font-label-md hover:bg-primary/5 active:scale-95 transition-all text-xs">
                    <%= t.langSwitchBtn %>
                </a>
                <a href="/menu" class="bg-primary text-on-primary px-6 py-2.5 rounded-lg font-label-md active:scale-95 duration-200 shadow-sm hover:bg-primary-container transition-all text-center">
                    <%= t.btnPreorder %>
                </a>
            </div>
        </nav>
    </header>

    <main class="flex-grow">
        <!-- Hero Section -->
        <section class="pt-xl pb-lg px-gutter max-w-container-max mx-auto text-center">
            <h1 class="font-headline-xl text-headline-xl text-on-background mb-sm"><%= t.kindWords %></h1>
            <p class="font-body-lg text-body-lg text-on-surface-variant max-w-2xl mx-auto"><%= t.kindWordsSub %></p>
        </section>

        <!-- Stats Section -->
        <section class="py-md bg-surface-container-low border-y border-outline-variant/30">
            <div class="max-w-container-max mx-auto px-gutter grid grid-cols-1 md:grid-cols-3 gap-md text-center">
                <div class="space-y-1">
                    <span class="font-headline-xl text-headline-xl text-primary font-bold">500+</span>
                    <p class="font-label-md text-on-surface-variant"><%= t.satisfiedTitle %></p>
                </div>
                <div class="space-y-1">
                    <div class="flex justify-center items-center gap-1">
                        <span class="font-headline-xl text-headline-xl text-primary font-bold">4.9</span>
                        <span class="material-symbols-outlined rating-star-fill text-[32px]">star</span>
                    </div>
                    <p class="font-label-md text-on-surface-variant"><%= t.averageSatisfaction %></p>
                </div>
                <div class="space-y-1">
                    <span class="font-headline-xl text-headline-xl text-primary font-bold">100%</span>
                    <p class="font-label-md text-on-surface-variant"><%= t.recommendedLocals %></p>
                </div>
            </div>
        </section>

        <!-- Main Reviews Grid & Form Section -->
        <section class="py-xl max-w-container-max mx-auto px-gutter grid grid-cols-1 lg:grid-cols-12 gap-lg items-start">
            
            <!-- Review Submission Form -->
            <div class="lg:col-span-4 bg-surface-container p-md rounded-xl border border-outline-variant/30 space-y-md">
                <div>
                    <h3 class="font-headline-md text-headline-md text-on-surface"><%= t.shareReviewTitle %></h3>
                    <p class="font-body-md text-body-md text-on-surface-variant"><%= t.shareReviewSub %></p>
                </div>
                
                <% if (submitted) { %>
                    <div class="bg-tertiary-container/30 text-on-tertiary-container p-md rounded-lg border border-tertiary-container/50">
                        <p class="font-label-md"><%= t.reviewSubmittedSuccess %></p>
                    </div>
                <% } %>

                <form action="/reviews" method="POST" class="space-y-sm">
                    <div class="space-y-xs">
                        <label class="font-label-sm text-on-surface-variant block"><%= t.labelName %></label>
                        <input type="text" name="customer_name" required class="w-full bg-background border border-outline-variant/50 rounded-lg p-sm focus:outline-none focus:border-primary font-body-md"/>
                    </div>
                    <div class="space-y-xs">
                        <label class="font-label-sm text-on-surface-variant block"><%= t.labelNeighborhood %></label>
                        <input type="text" name="customer_region" class="w-full bg-background border border-outline-variant/50 rounded-lg p-sm focus:outline-none focus:border-primary font-body-md"/>
                    </div>
                    <div class="space-y-xs">
                        <label class="font-label-sm text-on-surface-variant block"><%= t.labelRating %></label>
                        <select name="rating" required class="w-full bg-background border border-outline-variant/50 rounded-lg p-sm focus:outline-none focus:border-primary font-body-md">
                            <option value="5">⭐⭐⭐⭐⭐ (5/5)</option>
                            <option value="4">⭐⭐⭐⭐ (4/5)</option>
                            <option value="3">⭐⭐⭐ (3/5)</option>
                            <option value="2">⭐⭐ (2/5)</option>
                            <option value="1">⭐ (1/5)</option>
                        </select>
                    </div>
                    <div class="space-y-xs">
                        <label class="font-label-sm text-on-surface-variant block"><%= t.labelExperience %></label>
                        <textarea name="comment" rows="4" required placeholder="<%= t.placeholderExperience %>" class="w-full bg-background border border-outline-variant/50 rounded-lg p-sm focus:outline-none focus:border-primary font-body-md"></textarea>
                    </div>
                    <button type="submit" class="w-full bg-primary text-on-primary font-label-md py-3 rounded-lg hover:bg-primary-container active:scale-[0.98] transition-all">
                        <%= t.btnSubmitReview %>
                    </button>
                </form>
            </div>

            <!-- Approved Reviews List -->
            <div class="lg:col-span-8 space-y-md">
                <% reviews.forEach((rev) => { %>
                    <div class="bg-surface-container-lowest p-md rounded-xl border border-outline-variant/20 space-y-sm shadow-sm transition-all hover:shadow-md duration-300">
                        <div class="flex justify-between items-start">
                            <div>
                                <h4 class="font-headline-md text-headline-md text-on-surface font-semibold"><%= rev.customer_name %></h4>
                                <span class="text-on-surface-variant text-sm font-body-md"><%= rev.customer_region %></span>
                            </div>
                            <div class="flex gap-0.5">
                                <% for(let i=0; i<5; i++) { %>
                                    <span class="material-symbols-outlined text-[20px] <%= i < rev.rating ? 'rating-star-fill' : 'text-outline-variant' %>">star</span>
                                <% } %>
                            </div>
                        </div>
                        <p class="font-body-md text-body-md text-on-surface-variant leading-relaxed"><%= rev.comment %></p>
                    </div>
                <% }) %>
            </div>
        </section>
    </main>

    <!-- Footer -->
    <footer class="bg-surface-container-high border-t border-outline-variant/30 pt-xl pb-md">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-md px-gutter max-w-container-max mx-auto text-center md:text-left">
            <div>
                <img src="/images/logo/lockup.svg" alt="Hayla - Authentic Egyptian Homemade Food" class="h-10 md:h-12 w-auto mx-auto md:mx-0 mb-2" />
                <p class="font-body-md text-body-md text-on-surface-variant mb-6"><%= t.tagline %></p>
            </div>
            <div class="space-y-4">
                <h4 class="font-label-md text-on-surface font-bold uppercase tracking-widest"><%= lang === 'ar' ? 'روابط سريعة' : 'Navigation' %></h4>
                <nav class="flex flex-col gap-2 font-body-md text-on-surface-variant">
                    <a class="hover:text-primary transition-all underline decoration-primary/30 underline-offset-4" href="/about"><%= t.navStory %></a>
                    <a class="hover:text-primary transition-all underline decoration-primary/30 underline-offset-4" href="/menu"><%= t.navMenu %></a>
                    <a class="hover:text-primary transition-all underline decoration-primary/30 underline-offset-4" href="/contact"><%= t.navContact %></a>
                </nav>
            </div>
            <div class="space-y-4">
                <h4 class="font-label-md text-on-surface font-bold uppercase tracking-widest">Connect</h4>
                <nav class="flex flex-col gap-2 font-body-md text-on-surface-variant">
                    <a class="hover:text-primary transition-all underline decoration-primary/30 underline-offset-4" href="https://wa.me/<%= settings.whatsapp_number ? settings.whatsapp_number.replace(/\D/g, '') : '' %>">WhatsApp</a>
                </nav>
            </div>
        </div>
        <div class="max-w-container-max mx-auto px-gutter mt-xl pt-md border-t border-outline-variant/20 text-center">
            <p class="font-body-md text-body-md text-on-surface-variant/70">© 2024 <%= t.brandName %>. <%= t.tagline %>.</p>
        </div>
    </footer>
</body>
</html>
