<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= t.dir %>" class="scroll-smooth">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title><%= t.brandName %> - <%= t.orderPlaced %></title>
    <link rel="icon" type="image/svg+xml" href="/images/logo/icon.svg" />
    <link rel="apple-touch-icon" href="/images/logo/icon.svg" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&amp;family=Quicksand:wght@400;500;600;700&amp;family=Cairo:wght@400;600;700;750&amp;display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
    <script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            "colors": {
              "primary-container": "#b8583d",
              "on-background": "#1d1c18",
              "surface-container-high": "#ece7e1",
              "on-secondary-fixed": "#291800",
              "surface": "#fef9f2",
              "secondary-fixed-dim": "#fabb57",
              "error-container": "#ffdad6",
              "on-error": "#ffffff",
              "on-surface-variant": "#56423d",
              "secondary-fixed": "#ffddb0",
              "on-secondary-fixed-variant": "#614000",
              "tertiary-fixed-dim": "#b7cda8",
              "on-secondary": "#ffffff",
              "on-secondary-container": "#734d00",
              "surface-variant": "#e6e2db",
              "on-primary-fixed-variant": "#7d2c14",
              "tertiary": "#4e6143",
              "on-tertiary-container": "#f8ffee",
              "inverse-on-surface": "#f5f0e9",
              "secondary-container": "#fdbe5a",
              "on-primary-fixed": "#3b0900",
              "surface-dim": "#ded9d3",
              "surface-container-highest": "#e6e2db",
              "on-primary": "#ffffff",
              "on-tertiary-fixed": "#0f2008",
              "on-surface": "#1d1c18",
              "secondary": "#805600",
              "surface-tint": "#9c4329",
              "error": "#ba1a1a",
              "on-primary-container": "#fffbff",
              "primary": "#994127",
              "tertiary-container": "#667a5a",
              "primary-fixed-dim": "#ffb5a0",
              "outline-variant": "#dcc1ba",
              "primary-fixed": "#ffdbd1",
              "on-tertiary": "#ffffff",
              "on-error-container": "#93000a",
              "background": "#fef9f2",
              "inverse-surface": "#32302c",
              "outline": "#89726c",
              "surface-bright": "#fef9f2",
              "on-tertiary-fixed-variant": "#394c2f",
              "tertiary-fixed": "#d3e9c3",
              "surface-container-lowest": "#ffffff",
              "inverse-primary": "#ffb5a0",
              "surface-container-low": "#f8f3ec",
              "surface-container": "#f2ede6"
            },
            "borderRadius": {
              "DEFAULT": "0.25rem",
              "lg": "0.5rem",
              "xl": "0.75rem",
              "full": "9999px"
            },
            "spacing": {
              "xs": "4px",
              "gutter": "24px",
              "sm": "12px",
              "lg": "48px",
              "md": "24px",
              "base": "8px",
              "container-max": "1200px",
              "xl": "80px"
            },
            "fontFamily": {
              "body-lg": ["<%= lang === 'ar' ? 'Cairo' : 'Quicksand' %>", "sans-serif"],
              "body-md": ["<%= lang === 'ar' ? 'Cairo' : 'Quicksand' %>", "sans-serif"],
              "headline-lg": ["<%= lang === 'ar' ? 'Cairo' : 'Playfair Display' %>", "serif"],
              "headline-md": ["<%= lang === 'ar' ? 'Cairo' : 'Playfair Display' %>", "serif"],
              "headline-lg-mobile": ["<%= lang === 'ar' ? 'Cairo' : 'Playfair Display' %>", "serif"],
              "label-md": ["<%= lang === 'ar' ? 'Cairo' : 'Quicksand' %>", "sans-serif"],
              "label-sm": ["<%= lang === 'ar' ? 'Cairo' : 'Quicksand' %>", "sans-serif"],
              "headline-xl": ["<%= lang === 'ar' ? 'Cairo' : 'Playfair Display' %>", "serif"]
            }
          },
        },
      }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            vertical-align: middle;
        }
        .linen-texture {
            position: fixed;
            inset: 0;
            z-index: -1;
            opacity: 0.04;
            pointer-events: none;
            background-image: url("https://www.transparenttextures.com/patterns/linen.png");
        }
    </style>
    <style>
        body {
            min-height: max(884px, 100dvh);
        }
    </style>
</head>
<body class="bg-background text-on-background font-body-md min-h-screen flex flex-col relative antialiased">
    <div class="linen-texture"></div>

    <!-- TopAppBar -->
    <header class="sticky top-0 w-full z-50 bg-surface/90 backdrop-blur-md shadow-sm">
        <nav class="flex justify-between items-center h-20 px-gutter max-w-container-max mx-auto">
            <div class="flex items-center gap-4">
                <span class="material-symbols-outlined text-primary text-2xl active:scale-95 duration-200">menu</span>
                <a href="/" class="flex items-center">
                    <img src="/images/logo/lockup.svg" alt="Hayla - Authentic Egyptian Homemade Food" class="h-10 md:h-12 w-auto" />
                </a>
            </div>
            <div class="hidden md:flex gap-8 items-center">
                <a class="font-label-md text-on-surface-variant hover:text-primary transition-colors" href="/"><%= t.navHome %></a>
                <a class="font-label-md text-on-surface-variant hover:text-primary transition-colors" href="/about"><%= t.navStory %></a>
                <a class="font-label-md text-on-surface-variant hover:text-primary transition-colors" href="/menu"><%= t.navMenu %></a>
                <a class="font-label-md text-on-surface-variant hover:text-primary transition-colors" href="/reviews"><%= t.navReviews %></a>
                <a class="font-label-md text-on-surface-variant hover:text-primary transition-colors" href="/contact"><%= t.navContact %></a>
            </div>
        </nav>
    </header>

    <main class="flex-grow flex items-center justify-center py-xl px-gutter">
        <div class="max-w-xl w-full bg-surface-container p-md rounded-xl border border-outline-variant/30 text-center space-y-md shadow-lg">
            
            <div class="w-20 h-20 bg-tertiary-fixed text-on-tertiary-fixed rounded-full flex items-center justify-center mx-auto border-4 border-white shadow-sm">
                <span class="material-symbols-outlined text-[48px]">check_circle</span>
            </div>

            <div class="space-y-xs">
                <h1 class="font-headline-xl text-headline-xl text-on-surface"><%= t.orderPlaced %></h1>
                <p class="font-body-lg text-body-lg text-on-surface-variant">
                    <%= t.orderPlacedSub.replace('{name}', order.customer_name) %>
                </p>
                <p class="font-label-md text-primary font-bold text-lg"><%= t.orderIdLabel.replace('{id}', order.id) %></p>
            </div>

            <!-- Order Details -->
            <div class="bg-background rounded-xl p-md border border-outline-variant/20 text-left font-body-md text-body-md space-y-sm">
                <h3 class="font-label-md text-on-surface border-b border-outline-variant/10 pb-xs text-center"><%= t.summaryTitle %></h3>
                
                <!-- Items list -->
                <div class="space-y-xs">
                    <% items.forEach(item => { %>
                        <div class="flex justify-between items-center text-sm">
                            <span class="text-on-surface-variant"><%= item.name %> <span class="font-bold">x <%= item.quantity %></span></span>
                            <span class="text-on-surface font-semibold"><%= item.price * item.quantity %> EGP</span>
                        </div>
                    <% }) %>
                </div>

                <!-- Fees & Total -->
                <div class="pt-sm border-t border-outline-variant/10 space-y-xs text-sm">
                    <div class="flex justify-between text-on-surface-variant">
                        <span><%= t.fulfillmentLabel %></span>
                        <span class="font-semibold"><%= order.delivery_type === 'delivery' ? t.fulfillmentDelivery : t.fulfillmentPickup %></span>
                    </div>
                    <% if (order.delivery_type === 'delivery') { %>
                        <div class="flex flex-col text-on-surface-variant pb-1">
                            <span class="text-xs font-bold text-primary"><%= t.addressLabel %></span>
                            <span class="text-xs italic leading-tight"><%= order.address %></span>
                        </div>
                    <% } %>
                    <div class="flex justify-between text-on-surface-variant">
                        <span><%= t.paymentMethodLabel %></span>
                        <span class="font-semibold">
                            <%= order.payment_method === 'cod' ? t.paymentCod : (order.payment_method === 'instapay' ? t.paymentInstapay : t.paymentVodafone) %>
                        </span>
                    </div>
                    <div class="flex justify-between text-on-surface font-bold text-base pt-sm border-t border-outline-variant/15">
                        <span><%= t.summaryGrandTotal %></span>
                        <span class="text-primary"><%= order.total_amount + (order.delivery_type === 'delivery' ? 50 : 0) %> EGP</span>
                    </div>
                </div>
            </div>

            <!-- Call to Actions -->
            <div class="pt-4 space-y-sm">
                <% if (order.payment_method !== 'cod') { %>
                    <!-- Digital Payment flow -->
                    <div class="bg-primary/5 rounded-lg border border-primary/20 p-md space-y-sm">
                        <h4 class="font-label-md text-primary font-bold"><%= t.actionRequired %></h4>
                        <p class="font-body-md text-body-md text-on-surface-variant leading-relaxed text-xs">
                            <%= t.whatsappActionDesc %>
                        </p>
                        <% 
                            let whatsappMsg = `Hello Hayla Kitchen! I would like to complete my pre-order.\nOrder ID: #${order.id}\nName: ${order.customer_name}\nTotal: ${order.total_amount + (order.delivery_type === 'delivery' ? 50 : 0)} EGP\nMethod: ${order.payment_method}`;
                            let whatsappLink = getWhatsappLink(settings.whatsapp_number, whatsappMsg);
                        %>
                        <a href="<%= whatsappLink %>" target="_blank" class="w-full bg-[#25D366] text-white font-label-md py-3 rounded-lg flex items-center justify-center gap-2 active:scale-95 duration-200 shadow-md">
                            <span class="material-symbols-outlined">chat</span> <%= t.btnCompleteWhatsapp %>
                        </a>
                    </div>
                <% } else { %>
                    <div class="bg-tertiary-container/20 rounded-lg border border-tertiary-container/30 p-md">
                        <h4 class="font-label-md text-tertiary font-bold"><%= t.codInfoTitle %></h4>
                        <p class="font-body-md text-body-md text-on-surface-variant text-xs mt-1">
                            <%= t.codInfoDesc.replace('{amount}', order.total_amount + (order.delivery_type === 'delivery' ? 50 : 0)) %>
                        </p>
                    </div>
                <% } %>

                <a href="/" class="w-full block border-2 border-primary text-primary font-label-md py-3 rounded-lg hover:bg-primary/5 active:scale-[0.98] transition-all">
                    <%= t.btnReturnHome %>
                </a>
            </div>

        </div>
    </main>

    <!-- Footer -->
    <footer class="bg-surface-container-high border-t border-outline-variant/30 pt-xl pb-md">
        <div class="max-w-container-max mx-auto px-gutter text-center">
            <p class="font-body-md text-body-md text-on-surface-variant/70">© 2024 <%= t.brandName %>. <%= t.tagline %>.</p>
        </div>
    </footer>
</body>
</html>
