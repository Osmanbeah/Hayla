<!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= t.dir %>" class="scroll-smooth">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title><%= t.brandName %> - <%= t.navContact %></title>
    <link rel="icon" type="image/svg+xml" href="/images/logo/icon.svg" />
    <link rel="apple-touch-icon" href="/images/logo/icon.svg" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&amp;family=Quicksand:wght@400;500;600;700&amp;family=Cairo:wght@400;600;700;750&amp;display=swap" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
    <script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            "colors": {
              "primary-container": "#b8583d",
              "on-background": "#1d1c18",
              "surface-container-high": "#ece7e1",
              "on-secondary-fixed": "#291800",
              "surface": "#fef9f2",
              "secondary-fixed-dim": "#fabb57",
              "error-container": "#ffdad6",
              "on-error": "#ffffff",
              "on-surface-variant": "#56423d",
              "secondary-fixed": "#ffddb0",
              "on-secondary-fixed-variant": "#614000",
              "tertiary-fixed-dim": "#b7cda8",
              "on-secondary": "#ffffff",
              "on-secondary-container": "#734d00",
              "surface-variant": "#e6e2db",
              "on-primary-fixed-variant": "#7d2c14",
              "tertiary": "#4e6143",
              "on-tertiary-container": "#f8ffee",
              "inverse-on-surface": "#f5f0e9",
              "secondary-container": "#fdbe5a",
              "on-primary-fixed": "#3b0900",
              "surface-dim": "#ded9d3",
              "surface-container-highest": "#e6e2db",
              "on-primary": "#ffffff",
              "on-tertiary-fixed": "#0f2008",
              "on-surface": "#1d1c18",
              "secondary": "#805600",
              "surface-tint": "#9c4329",
              "error": "#ba1a1a",
              "on-primary-container": "#fffbff",
              "primary": "#994127",
              "tertiary-container": "#667a5a",
              "primary-fixed-dim": "#ffb5a0",
              "outline-variant": "#dcc1ba",
              "primary-fixed": "#ffdbd1",
              "on-tertiary": "#ffffff",
              "on-error-container": "#93000a",
              "background": "#fef9f2",
              "inverse-surface": "#32302c",
              "outline": "#89726c",
              "surface-bright": "#fef9f2",
              "on-tertiary-fixed-variant": "#394c2f",
              "tertiary-fixed": "#d3e9c3",
              "surface-container-lowest": "#ffffff",
              "inverse-primary": "#ffb5a0",
              "surface-container-low": "#f8f3ec",
              "surface-container": "#f2ede6"
            },
            "borderRadius": {
              "DEFAULT": "0.25rem",
              "lg": "0.5rem",
              "xl": "0.75rem",
              "full": "9999px"
            },
            "spacing": {
              "xs": "4px",
              "gutter": "24px",
              "sm": "12px",
              "lg": "48px",
              "md": "24px",
              "base": "8px",
              "container-max": "1200px",
              "xl": "80px"
            },
            "fontFamily": {
              "body-lg": ["<%= lang === 'ar' ? 'Cairo' : 'Quicksand' %>", "sans-serif"],
              "body-md": ["<%= lang === 'ar' ? 'Cairo' : 'Quicksand' %>", "sans-serif"],
              "headline-lg": ["<%= lang === 'ar' ? 'Cairo' : 'Playfair Display' %>", "serif"],
              "headline-md": ["<%= lang === 'ar' ? 'Cairo' : 'Playfair Display' %>", "serif"],
              "headline-lg-mobile": ["<%= lang === 'ar' ? 'Cairo' : 'Playfair Display' %>", "serif"],
              "label-md": ["<%= lang === 'ar' ? 'Cairo' : 'Quicksand' %>", "sans-serif"],
              "label-sm": ["<%= lang === 'ar' ? 'Cairo' : 'Quicksand' %>", "sans-serif"],
              "headline-xl": ["<%= lang === 'ar' ? 'Cairo' : 'Playfair Display' %>", "serif"]
            }
          },
        },
      }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
            vertical-align: middle;
        }
        .linen-texture {
            position: fixed;
            inset: 0;
            z-index: -1;
            opacity: 0.04;
            pointer-events: none;
            background-image: url("https://www.transparenttextures.com/patterns/linen.png");
        }
    </style>
    <style>
        body {
            min-height: max(884px, 100dvh);
        }
    </style>
</head>
<body class="bg-background text-on-background font-body-md min-h-screen flex flex-col relative antialiased">
    <div class="linen-texture"></div>

    <!-- TopAppBar -->
    <header class="sticky top-0 w-full z-50 bg-surface/90 backdrop-blur-md shadow-sm">
        <nav class="flex justify-between items-center h-20 px-gutter max-w-container-max mx-auto">
            <div class="flex items-center gap-4">
                <button onclick="toggleMobileDrawer()" class="material-symbols-outlined text-primary text-2xl active:scale-95 duration-200 select-none cursor-pointer bg-transparent border-none p-0 leading-none" style="font-family:'Material Symbols Outlined';user-select:none;-webkit-user-select:none">menu</button>
                <a href="/" class="flex items-center">
                    <img src="/images/logo/lockup.svg" alt="Hayla - Authentic Egyptian Homemade Food" class="h-10 md:h-12 w-auto" />
                </a>
            </div>
            <div class="hidden md:flex gap-8 items-center">
                <a class="font-label-md text-on-surface-variant hover:text-primary transition-colors" href="/"><%= t.navHome %></a>
                <a class="font-label-md text-on-surface-variant hover:text-primary transition-colors" href="/about"><%= t.navStory %></a>
                <a class="font-label-md text-on-surface-variant hover:text-primary transition-colors" href="/menu"><%= t.navMenu %></a>
                <a class="font-label-md text-on-surface-variant hover:text-primary transition-colors" href="/reviews"><%= t.navReviews %></a>
                <a class="font-label-md text-primary border-b-2 border-primary" href="/contact"><%= t.navContact %></a>
            </div>
            <div class="flex items-center gap-4">
                <!-- Language Switcher Button -->
                <a href="/lang/<%= lang === 'ar' ? 'en' : 'ar' %>" class="border border-primary text-primary px-3 py-1.5 rounded-lg font-label-md hover:bg-primary/5 active:scale-95 transition-all text-xs">
                    <%= t.langSwitchBtn %>
                </a>
                <a href="/menu" class="bg-primary text-on-primary px-6 py-2.5 rounded-lg font-label-md active:scale-95 duration-200 shadow-sm hover:bg-primary-container transition-all text-center">
                    <%= t.btnPreorder %>
                </a>
            </div>
        </nav>
    </header>

    <main class="flex-grow">
        <!-- Hero Section -->
        <section class="pt-xl pb-lg px-gutter max-w-container-max mx-auto text-center">
            <h1 class="font-headline-xl text-headline-xl text-on-background mb-sm"><%= t.contactTitle %></h1>
            <p class="font-body-lg text-body-lg text-on-surface-variant max-w-2xl mx-auto"><%= t.contactSub %></p>
        </section>

        <!-- Channels & Form -->
        <section class="pb-xl max-w-container-max mx-auto px-gutter grid grid-cols-1 lg:grid-cols-12 gap-lg items-stretch">
            
            <!-- Direct channels -->
            <div class="lg:col-span-5 bg-surface-container p-md rounded-xl border border-outline-variant/30 flex flex-col justify-between space-y-md">
                <div class="space-y-md">
                    <h3 class="font-headline-md text-headline-md text-on-surface"><%= t.directChannels %></h3>
                    
                    <div class="space-y-sm">
                        <!-- Phone -->
                        <div class="flex items-start gap-4 p-4 bg-background rounded-lg border border-outline-variant/20">
                            <span class="material-symbols-outlined text-primary text-[28px] mt-1">call</span>
                            <div>
                                <h4 class="font-label-md text-on-surface"><%= t.contactPhone %></h4>
                                <p class="font-body-md text-on-surface-variant"><%= settings.whatsapp_number || 'N/A' %></p>
                            </div>
                        </div>

                        <!-- Email -->
                        <div class="flex items-start gap-4 p-4 bg-background rounded-lg border border-outline-variant/20">
                            <span class="material-symbols-outlined text-primary text-[28px] mt-1">mail</span>
                            <div>
                                <h4 class="font-label-md text-on-surface"><%= t.contactEmail %></h4>
                                <p class="font-body-md text-on-surface-variant">kitchen@hayla.com</p>
                            </div>
                        </div>

                        <!-- Location -->
                        <div class="flex items-start gap-4 p-4 bg-background rounded-lg border border-outline-variant/20">
                            <span class="material-symbols-outlined text-primary text-[28px] mt-1">location_on</span>
                            <div>
                                <h4 class="font-label-md text-on-surface"><%= t.contactLocation %></h4>
                                <p class="font-body-md text-on-surface-variant"><%= t.contactLocationDesc %></p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- WhatsApp Callout -->
                <% if (settings.whatsapp_number) { %>
                    <a href="<%= getWhatsappLink(settings.whatsapp_number) %>" class="w-full bg-[#25D366] text-white text-center font-label-md py-4 rounded-lg flex items-center justify-center gap-2 active:scale-95 duration-200 shadow-md">
                        <span class="material-symbols-outlined">chat</span> <%= t.orderViaWhatsapp %>
                    </a>
                <% } %>
            </div>

            <!-- WhatsApp Direct Contact Card -->
            <div class="lg:col-span-7 bg-surface-container-low p-md rounded-xl border border-outline-variant/30 flex flex-col items-center justify-center text-center p-xl space-y-md min-h-[350px]">
                <div class="w-20 h-20 bg-[#25D366]/10 text-[#25D366] rounded-full flex items-center justify-center mx-auto mb-2">
                    <svg class="w-12 h-12 fill-current" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.713-1.455L0 24zm6.59-4.846c1.66.986 3.284 1.489 4.936 1.49 5.375 0 9.75-4.332 9.752-9.654.002-2.58-1.01-5.003-2.846-6.841-1.835-1.838-4.274-2.849-6.853-2.85-5.378 0-9.754 4.331-9.757 9.656-.001 1.77.472 3.498 1.371 5.031L2.247 21.5l5.733-1.503c1.558.85 3.13 1.258 4.667 1.258zM17.15 15.3c-.279-.14-1.65-.815-1.905-.907-.255-.093-.441-.14-.627.14-.186.281-.72.907-.882 1.093-.163.186-.326.21-.605.07-1.127-.562-1.92-1.01-2.67-2.302-.198-.344.198-.32.567-1.054.07-.14.035-.262-.017-.367-.052-.105-.441-1.06-.605-1.454-.16-.385-.335-.332-.46-.338-.119-.006-.255-.007-.39-.007-.136 0-.356.05-.543.256-.187.206-.714.698-.714 1.701 0 1.003.73 1.973.832 2.111.101.139 1.437 2.195 3.483 3.078.487.21 1.002.336 1.516.398.498.06.953.029 1.31-.024.398-.058 1.65-.675 1.884-1.328.234-.652.234-1.213.164-1.328-.07-.116-.256-.205-.536-.345z"/>
                    </svg>
                </div>
                <h3 class="font-headline-md text-headline-md text-on-surface">
                    <%= lang === 'ar' ? 'ØªÙˆØ§ØµÙ„ Ù…Ø¹Ù†Ø§ Ø¹Ø¨Ø± Ø§Ù„ÙˆØ§ØªØ³Ø§Ø¨' : 'Contact Us on WhatsApp' %>
                </h3>
                <p class="font-body-md text-body-md text-on-surface-variant max-w-md">
                    <%= lang === 'ar' ? 'Ù…Ø·Ø¨Ø®Ù†Ø§ ÙŠØ³ØªÙ‚Ø¨Ù„ ÙƒØ§ÙØ© Ø§Ù„Ø·Ù„Ø¨Ø§Øª ÙˆØ§Ù„Ø§Ø³ØªÙØ³Ø§Ø±Ø§Øª Ø­ØµØ±ÙŠØ§Ù‹ Ø¹Ø¨Ø± Ø§Ù„ÙˆØ§ØªØ³Ø§Ø¨. Ø§Ø¶ØºØ· Ø¹Ù„Ù‰ Ø§Ù„Ø²Ø± Ø¨Ø§Ù„Ø£Ø³ÙÙ„ Ù„Ø¨Ø¯Ø¡ Ø§Ù„Ù…Ø­Ø§Ø¯Ø«Ø© Ù…Ø¨Ø§Ø´Ø±Ø©.' : 'Our kitchen receives all inquiries and requests exclusively via WhatsApp. Click the button below to start a chat with us directly.' %>
                </p>
                <% if (settings.whatsapp_number) { %>
                    <a href="<%= getWhatsappLink(settings.whatsapp_number) %>" target="_blank" class="bg-[#25D366] text-white font-label-md text-base px-8 py-4 rounded-lg flex items-center justify-center gap-2 active:scale-95 duration-200 shadow-md hover:bg-[#22c35e] transition-all">
                        <span class="material-symbols-outlined">chat</span>
                        <%= lang === 'ar' ? 'ØªÙˆØ§ØµÙ„ Ø§Ù„Ø¢Ù† Ø¹Ø¨Ø± Ø§Ù„ÙˆØ§ØªØ³Ø§Ø¨' : 'Start WhatsApp Chat' %>
                    </a>
                <% } else { %>
                    <span class="text-error font-bold font-label-md">
                        <%= lang === 'ar' ? 'Ù„Ù… ÙŠØªÙ… Ø¥Ø¹Ø¯Ø§Ø¯ Ø±Ù‚Ù… Ø§Ù„ÙˆØ§ØªØ³Ø§Ø¨ Ø¨Ø¹Ø¯.' : 'WhatsApp number is not configured.' %>
                    </span>
                <% } %>
            </div>
        </section>
    </main>

    <!-- Mobile Navigation Drawer -->
    <div id="mobile-drawer" class="fixed inset-y-0 <%= lang === 'ar' ? 'right-0' : 'left-0' %> w-72 bg-surface shadow-2xl z-[150] transform <%= lang === 'ar' ? 'translate-x-full' : '-translate-x-full' %> transition-transform duration-300 flex flex-col border-r border-outline-variant/30 font-body-md">
        <div class="p-md border-b border-outline-variant/30 flex justify-between items-center bg-surface-container-low">
            <img src="/images/logo/lockup.svg" alt="Hayla Logo" class="h-8 w-auto" />
            <button onclick="toggleMobileDrawer()" class="text-on-surface hover:text-primary">
                <span class="material-symbols-outlined text-[32px]">close</span>
            </button>
        </div>
        <div class="flex flex-col p-md space-y-sm text-lg font-label-md">
            <a class="py-sm border-b border-outline-variant/10 text-on-surface-variant hover:text-primary transition-colors flex items-center justify-between" href="/">
                <span><%= t.navHome %></span>
                <span class="material-symbols-outlined text-sm"><%= lang === 'ar' ? 'chevron_left' : 'chevron_right' %></span>
            </a>
            <a class="py-sm border-b border-outline-variant/10 text-on-surface-variant hover:text-primary transition-colors flex items-center justify-between" href="/about">
                <span><%= t.navStory %></span>
                <span class="material-symbols-outlined text-sm"><%= lang === 'ar' ? 'chevron_left' : 'chevron_right' %></span>
            </a>
            <a class="py-sm border-b border-outline-variant/10 text-on-surface-variant hover:text-primary transition-colors flex items-center justify-between" href="/menu">
                <span><%= t.navMenu %></span>
                <span class="material-symbols-outlined text-sm"><%= lang === 'ar' ? 'chevron_left' : 'chevron_right' %></span>
            </a>
            <a class="py-sm border-b border-outline-variant/10 text-on-surface-variant hover:text-primary transition-colors flex items-center justify-between" href="/reviews">
                <span><%= t.navReviews %></span>
                <span class="material-symbols-outlined text-sm"><%= lang === 'ar' ? 'chevron_left' : 'chevron_right' %></span>
            </a>
            <a class="py-sm border-b border-outline-variant/10 text-on-surface-variant hover:text-primary transition-colors flex items-center justify-between" href="/contact">
                <span><%= t.navContact %></span>
                <span class="material-symbols-outlined text-sm"><%= lang === 'ar' ? 'chevron_left' : 'chevron_right' %></span>
            </a>
            
            <div class="pt-md flex flex-col gap-sm">
                <a href="/lang/<%= lang === 'ar' ? 'en' : 'ar' %>" class="border border-primary text-primary px-4 py-2 rounded-lg font-label-md hover:bg-primary/5 transition-all text-sm text-center">
                    <%= t.langSwitchBtn %>
                </a>
                <a href="/menu" class="bg-primary text-on-primary px-4 py-2 rounded-lg font-label-md hover:bg-primary-container transition-all text-sm text-center">
                    <%= t.btnPreorder %>
                </a>
            </div>
        </div>
    </div>
    
    <!-- Backdrop for Mobile Drawer -->
    <div id="mobile-backdrop" onclick="toggleMobileDrawer()" class="fixed inset-0 bg-black/40 z-[140] hidden transition-opacity duration-300"></div>

    <!-- Footer -->
    <footer class="bg-surface-container-high border-t border-outline-variant/30 pt-xl pb-md">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-md px-gutter max-w-container-max mx-auto text-center md:text-left">
            <div>
                <img src="/images/logo/lockup.svg" alt="Hayla - Authentic Egyptian Homemade Food" class="h-10 md:h-12 w-auto mx-auto md:mx-0 mb-2" />
                <p class="font-body-md text-body-md text-on-surface-variant mb-6"><%= t.tagline %></p>
            </div>
            <div class="space-y-4">
                <h4 class="font-label-md text-on-surface font-bold uppercase tracking-widest"><%= lang === 'ar' ? 'Ø±ÙˆØ§Ø¨Ø· Ø³Ø±ÙŠØ¹Ø©' : 'Navigation' %></h4>
                <nav class="flex flex-col gap-2 font-body-md text-on-surface-variant">
                    <a class="hover:text-primary transition-all underline decoration-primary/30 underline-offset-4" href="/about"><%= t.navStory %></a>
                    <a class="hover:text-primary transition-all underline decoration-primary/30 underline-offset-4" href="/menu"><%= t.navMenu %></a>
                    <a class="hover:text-primary transition-all underline decoration-primary/30 underline-offset-4" href="/contact"><%= t.navContact %></a>
                </nav>
            </div>
            <div class="space-y-4">
                <h4 class="font-label-md text-on-surface font-bold uppercase tracking-widest">Connect</h4>
                <nav class="flex flex-col gap-2 font-body-md text-on-surface-variant">
                    <a class="hover:text-primary transition-all underline decoration-primary/30 underline-offset-4" href="https://wa.me/<%= settings.whatsapp_number ? settings.whatsapp_number.replace(/\D/g, '') : '' %>">WhatsApp</a>
                </nav>
            </div>
        </div>
        <div class="max-w-container-max mx-auto px-gutter mt-xl pt-md border-t border-outline-variant/20 text-center">
            <p class="font-body-md text-body-md text-on-surface-variant/70">Â© 2024 <%= t.brandName %>. <%= t.tagline %>.</p>
        </div>
    </footer>
    <script>
        function toggleMobileDrawer() {
            const drawer = document.getElementById('mobile-drawer');
            const backdrop = document.getElementById('mobile-backdrop');
            const isRtl = "<%= t.dir %>" === "rtl";
            
            let isOpen = isRtl 
                ? !drawer.classList.contains('translate-x-full')
                : !drawer.classList.contains('-translate-x-full');

            if (isOpen) {
                if (isRtl) {
                    drawer.classList.add('translate-x-full');
                } else {
                    drawer.classList.add('-translate-x-full');
                }
                backdrop.classList.add('hidden');
            } else {
                if (isRtl) {
                    drawer.classList.remove('translate-x-full');
                } else {
                    drawer.classList.remove('-translate-x-full');
                }
                backdrop.classList.remove('hidden');
            }
        }
    </script>
</body>
</html>

